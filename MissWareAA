visuals.peek_indicator = {
	fixed_position = nil,
	is_active = false,
	rising_particles = {},

	spawn_particle = function(self, cx, cy, cz, r, speed)
		if #self.rising_particles > 60 then return end
		local angle = math.random() * math.pi * 2
		table.insert(self.rising_particles, {
			x = cx + math.cos(angle) * r,
			y = cy + math.sin(angle) * r,
			z = cz,
			vx = (math.random() - 0.5) * 8 * speed,
			vy = (math.random() - 0.5) * 8 * speed,
			vz = math.random(15, 30) * speed,
			life = math.random() * 1.2 + 0.8,
			spawn_time = globals.realtime(),
			size = math.random() * 1.2 + 0.8,
			alpha = 220
		})
	end,

	draw_particles = function(self, r, g, b)
		local dt = globals.frametime()
		if dt <= 0 then dt = 0.016 end
		local now = globals.realtime()

		for i = #self.rising_particles, 1, -1 do
			local p = self.rising_particles[i]
			p.x, p.y, p.z = p.x + p.vx * dt, p.y + p.vy * dt, p.z + p.vz * dt
			p.vz, p.vx, p.vy = p.vz * 0.985, p.vx * 0.99, p.vy * 0.99

			local age = now - p.spawn_time
			if age > p.life then
				table.remove(self.rising_particles, i)
			else
				local life_ratio = 1 - (age / p.life)
				local alpha = p.alpha * life_ratio * life_ratio
				local sx, sy = renderer.world_to_screen(p.x, p.y, p.z)
				if sx and sy then
					local speed_2d = math.sqrt(p.vx^2 + p.vy^2)
					if speed_2d < 1 then speed_2d = 1 end
					local len = math.min(p.size * 2.0 * life_ratio, 12)
					local ex = sx - (p.vx / speed_2d) * len
					local ey = sy - (p.vy / speed_2d) * len
					renderer.line(sx, sy, ex, ey, r, g, b, alpha * 0.6)
					renderer.line(sx, sy, ex, ey, 255, 255, 255, alpha)
					renderer.circle(sx, sy, 255, 255, 255, alpha * 0.5, 2, 0, 1)
				end
			end
		end
	end,

	draw_orbiting = function(self, cx, cy, cz, r, col_out, speed)
		local particle_count = 4
		local time = globals.realtime() * speed
		local alpha = col_out[4]
		
		for i = 0, particle_count - 1 do
			local angle = time + (i * (math.pi * 2 / particle_count))
			local px = cx + math.cos(angle) * r
			local py = cy + math.sin(angle) * r
			local pz = cz
			
			local sx, sy = renderer.world_to_screen(px, py, pz)
			if sx and sy then
				for j = 1, 3 do
					local p_alpha = math.floor(alpha / (j * 1.5))
					local p_radius = j + 2
					renderer.circle(sx, sy, col_out[1], col_out[2], col_out[3], p_alpha, p_radius, 0, 1)
				end
				renderer.circle(sx, sy, 255, 255, 255, alpha, 2, 0, 1)
			end
		end
	end,

	draw_circle = function(self, cx, cy, cz, r, seg, col_out, col_in, bloom, blur, glow, time, speed)
		local pts = {}
		for i = 0, seg do
			local a = (i / seg) * math.pi * 2
			local sx, sy = renderer.world_to_screen(cx + math.cos(a) * r, cy + math.sin(a) * r, cz)
			if sx then table.insert(pts, {x = sx, y = sy}) end
		end
		if #pts < 3 then return end

		local scx, scy = renderer.world_to_screen(cx, cy, cz)
		if not scx then return end

		local alpha_mult = 1 - (blur / 100 * 0.5)
		local in_a = math.floor(col_in[4] * alpha_mult)
		local out_a = math.floor(col_out[4] * alpha_mult)

		if bloom.enabled and bloom.int > 0 then
			local b_int = bloom.int
			if glow then
				local pulse = (math.sin(time * speed * 1.5) + 1) / 2
				b_int = b_int * (0.5 + pulse * 1.0)
			end
			local base_alpha = math.floor(b_int * 1.5 * alpha_mult)
			for l = 1, bloom.qual do
				local prog = l / bloom.qual
				local lr = r * (1 + prog * 0.8)
				local la = math.floor(base_alpha * (1 - prog * 0.8))
				if la > 0 then
					local bpts = {}
					for i = 0, seg do
						local a = (i / seg) * math.pi * 2
						local sx, sy = renderer.world_to_screen(cx + math.cos(a) * lr, cy + math.sin(a) * lr, cz)
						if sx then table.insert(bpts, {x = sx, y = sy}) end
					end
					if #bpts >= 3 then
						local bla = math.floor(la * 0.4 * alpha_mult)
						local bll = math.floor(la * 0.3 * alpha_mult)
						for i = 1, #bpts - 1 do
							renderer.triangle(scx, scy, bpts[i].x, bpts[i].y, bpts[i+1].x, bpts[i+1].y, col_in[1], col_in[2], col_in[3], bla)
						end
						renderer.triangle(scx, scy, bpts[#bpts].x, bpts[#bpts].y, bpts[1].x, bpts[1].y, col_in[1], col_in[2], col_in[3], bla)
						
						for i = 1, #bpts do
							local p1, p2 = bpts[i], bpts[i % #bpts + 1]
							if p1 and p2 then renderer.line(p1.x, p1.y, p2.x, p2.y, col_out[1], col_out[2], col_out[3], bll) end
						end
					end
				end
			end
		end

		for i = 1, #pts - 1 do
			renderer.triangle(scx, scy, pts[i].x, pts[i].y, pts[i+1].x, pts[i+1].y, col_in[1], col_in[2], col_in[3], in_a)
		end
		renderer.triangle(scx, scy, pts[#pts].x, pts[#pts].y, pts[1].x, pts[1].y, col_in[1], col_in[2], col_in[3], in_a)

		for i = 1, #pts do
			local p1, p2 = pts[i], pts[i % #pts + 1]
			if p1 and p2 then renderer.line(p1.x, p1.y, p2.x, p2.y, col_out[1], col_out[2], col_out[3], out_a) end
		end

		if blur > 20 then
			local blur_layers = math.floor(blur / 20)
			for l = 1, blur_layers do
				local br = r + l * 0.5
				local ba = math.floor(in_a * 0.3 / l)
				if ba > 5 then
					local bpts = {}
					for i = 0, seg do
						local a = (i / seg) * math.pi * 2
						local sx, sy = renderer.world_to_screen(cx + math.cos(a) * br, cy + math.sin(a) * br, cz)
						if sx then table.insert(bpts, {x = sx, y = sy}) end
					end
					if #bpts >= 3 then
						for i = 1, #bpts - 1 do
							renderer.triangle(scx, scy, bpts[i].x, bpts[i].y, bpts[i+1].x, bpts[i+1].y, col_in[1], col_in[2], col_in[3], ba)
						end
						renderer.triangle(scx, scy, bpts[#bpts].x, bpts[#bpts].y, bpts[1].x, bpts[1].y, col_in[1], col_in[2], col_in[3], ba)
					end
				end
			end
		end
	end,

	work = function(self)
		local cfg = vars.visuals.peek_anim
		if #self.rising_particles > 0 then
			local r, g, b = unpack(cfg.col_out.value)
			self:draw_particles(r, g, b)
		end

		if not cfg.on.value then
			self.fixed_position = nil
			self.is_active = false
			return
		end

		local active = cfg.key:get()
		if active then
			if not self.is_active and my.valid then
				local z = my.origin.z
				if not my.on_ground then
					local view_offset = entity.get_prop(my.entity, "m_vecViewOffset[2]") or 64
					z = z - view_offset + 5
				end
				self.fixed_position = {
					x = my.origin.x, y = my.origin.y, z = z + cfg.height.value,
					start = globals.realtime()
				}
				self.is_active = true
			end
		else
			self.is_active = false
			self.fixed_position = nil
		end

		if not self.is_active or not self.fixed_position then return end

		local anims = cfg.anims
		local speed = (cfg.speed and cfg.speed.value or 15) * 0.1
		local time = globals.realtime()
		local r = cfg.radius.value
		local col_in = {unpack(cfg.col_in.value)}
		local col_out = {unpack(cfg.col_out.value)}

		if anims:get("Entry") then
			local delta = time - self.fixed_position.start
			local prog = 1 - math.pow(1 - math.min(delta * 4, 1), 3)
			r = r * prog
		end
		if anims:get("Pulse") then r = r * (math.sin(time * speed * 2) * 0.08 + 0.92) end
		if anims:get("Fill breath") then col_in[4] = math.floor(col_in[4] * (math.sin(time * speed * 2) * 0.3 + 0.7)) end
		if anims:get("Rising sparks") and math.random(1, 2) == 1 then
			self:spawn_particle(self.fixed_position.x, self.fixed_position.y, self.fixed_position.z, r, speed)
		end

		self:draw_circle(self.fixed_position.x, self.fixed_position.y, self.fixed_position.z, r, 24, col_out, col_in, {enabled = cfg.bloom.on.value, int = cfg.bloom.int.value, qual = cfg.bloom.qual.value}, cfg.blur.value, anims:get("Glow"), time, speed)

		if anims:get("Particles") then
			self:draw_orbiting(self.fixed_position.x, self.fixed_position.y, self.fixed_position.z, r, col_out, speed)
		end
	end,
	run = function(self) callbacks.paint:set(function() self:work() end) end
}
