-- #region - Database

local db = {
	key = "missware",
	version = 3,
} do
	local data = database.read(db.key)

	if not data then
		data = {
			version = db.version,
			configs = {},
			stats = {
				killed = 0, evaded = 0, playtime = 0, loaded = 1
			},
		}
		database.write(db.key, data)
	end

	if data.version ~= db.version then
		data.version = db.version
	end

	if not data.stats then data.stats = {} end
	if not data.stats.killed then data.stats.killed = 0 end
	if not data.stats.evaded then data.stats.evaded = 0 end
	if not data.stats.playtime then data.stats.playtime = 0 end
	if not data.stats.loaded then data.stats.loaded = 1 end

	data.stats.loaded = data.stats.loaded + 1

	do
		local last_save = globals.realtime()
		local function automemo()
			local now = globals.realtime()
			local dt = now - last_save
			last_save = now

			data.stats.playtime = data.stats.playtime + dt / 3600
			debug("autosave, playtime: ", string.format("%.2f", data.stats.playtime), "h")
			client.fire_event("missware::database_write")
			database.write(db.key, data)
			client.delay_call(300, automemo)
		end
		client.delay_call(300, automemo)
	end

	defer(function ()
		data.stats.playtime = data.stats.playtime + (globals.realtime() - (data._session_start or globals.realtime())) / 3600
		database.write(db.key, data)
		database.flush()
	end)

	data._session_start = globals.realtime()

	setmetatable(db, {
		__index = data,
		__call = function (self, flush)
			database.write(db.key, data)
			if flush == true then database.flush() end
		end
	})
end

