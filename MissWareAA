-- #region - Confidence bar widget

hud.confidence_bar = widget.new("confidence_bar", sc.x - 60, sc.y + 80, 120, 8, {
	border = { asc.x - 100, asc.y, asc.x + 100, asc.y + 200 },
	rulers = { { true, asc.x, asc.y, 200 } }
})

hud.confidence_bar.smooth_value = 0.5
hud.confidence_bar.trend_indicator = 0

hud.confidence_bar.update = function (self)
	return anima.condition(
		self.progress,
		vars.antiaim.global.value and my.valid and not my.in_score,
		-4
	)
end

hud.confidence_bar.paint = function (self, x, y, w, h)
	local white = color.rgb(255, 255, 255)
	local text = colors.text or white
	local red = colors.red or text
	local yellow = colors.yellow or text
	local green = colors.green or text
	local accent = colors.accent or text

	local conf = confidence.get()
	self.smooth_value = anima.lerp(self.smooth_value, conf, 6)

	local level_name, level = confidence.get_level()
	local trend = confidence.get_trend(8)
	self.trend_indicator = anima.lerp(self.trend_indicator, trend, 4)

	local bar_colors = {
		[0] = { red, red.darken and red:darken(0.3) or red },
		[1] = { red, yellow },
		[2] = { yellow, yellow },
		[3] = { text.alphen and text:alphen(180) or text, text.alphen and text:alphen(100) or text },
		[4] = { green, accent },
		[5] = { accent, accent.brighten and accent:brighten(1.2) or accent },
	}

	local cols = bar_colors[level] or bar_colors[3]
	local fill_w = math.max(1, self.smooth_value * (w - 4))

	render.blur(x, y, w, h + 14)
	render.rectangle(x, y, w, h, colors.panel.g1, 4)
	render.rectangle(x + 2, y + 2, w - 4, h - 4, colors.black:alphen(64), 2)
	render.gradient(x + 2, y + 2, fill_w, h - 4, cols[1], cols[2], true)

	local tick_x = x + 2 + fill_w
	render.rectangle(tick_x - 1, y, 2, h, colors.white:alphen(180))

	local trend_str = ""
	if self.trend_indicator > 0.02 then trend_str = " ↑"
	elseif self.trend_indicator < -0.02 then trend_str = " ↓" end

	render.text(
		x + w * 0.5, y + h + 2,
		text:alphen(96), "c-", nil,
		string.format("%s %d%%%s", level_name:upper(), math.round(conf * 100), trend_str)
	)
end

