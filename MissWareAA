	threat_intel.classify_weapon = function (profile, weapon_ent)
		if not weapon_ent then return end

		local weapon_t = weapondata(weapon_ent)
		if not weapon_t then return end

		local wtype = weapon_t.weapon_type_int
		local wid = entity.get_prop(weapon_ent, "m_iItemDefinitionIndex") or 0

		if wid == profile.weapon_id then return end

		profile.weapon_id = wid
		profile.weapon_history:push({
			weapon_id = wid,
			weapon_type = wtype,
			time = globals.realtime(),
		})

		profile.is_awper = (wid == 9)
		profile.is_scout = (wid == 40)
		profile.is_autoper = (wid == 11 or wid == 38)

		if wtype == 2 or wtype == 3 then
			profile.is_rifler = true
			profile.weapon_class = "rifle"
		elseif wtype == 4 then
			profile.weapon_class = "smg"
			profile.is_rifler = false
		elseif wtype == 5 then
			profile.weapon_class = "shotgun"
			profile.is_rifler = false
		elseif wtype == 6 then
			profile.weapon_class = "sniper"
			profile.is_rifler = false
			if wid == 9 then
				profile.weapon_class = "awp"
			elseif wid == 40 then
				profile.weapon_class = "scout"
			elseif wid == 11 or wid == 38 then
				profile.weapon_class = "auto"
			end
		elseif wtype == 1 then
			profile.weapon_class = "pistol"
			profile.is_rifler = false
		elseif wtype == 0 then
			profile.weapon_class = "knife"
			profile.is_rifler = false
		elseif wtype == 9 then
			profile.weapon_class = "grenade"
			profile.is_rifler = false
		else
			profile.weapon_class = "other"
			profile.is_rifler = false
		end
	end

	threat_intel.record_shot = function (entindex, data)
		local profile = threat_intel.get_profile(entindex)
		local now = globals.realtime()

		profile.shots:push({
			time = now,
			tick = globals.tickcount(),
			distance = data.distance or 0,
			hitbox = data.hitbox or "unknown",
			hit = data.hit or false,
			damage = data.damage or 0,
			preset_active = antiaim.my.state or "default",
		})

		profile.total_shots = profile.total_shots + 1

		profile.timing.shot_timestamps:push(now)

		if data.hit then
			profile.hits:push({
				time = now,
				hitbox = data.hitbox,
				damage = data.damage,
				preset = antiaim.my.state,
			})
			profile.total_hits = profile.total_hits + 1
			profile.last_hit_time = now

			global_stats.total_hit = global_stats.total_hit + 1
			global_stats.current_evasion_streak = 0

			if data.damage then
				global_stats.damage_taken_total = global_stats.damage_taken_total + data.damage
				global_stats.damage_taken_round = global_stats.damage_taken_round + data.damage
				global_stats.hp_lost_history:push({
					time = now,
					damage = data.damage,
					attacker = entindex,
				})
			end

			profile.aa_effectiveness.current_preset_hits =
				profile.aa_effectiveness.current_preset_hits + 1

			local preset_id = antiaim.my.state or "default"
			if not profile.aa_effectiveness.per_preset[preset_id] then
				profile.aa_effectiveness.per_preset[preset_id] = { hits = 0, misses = 0 }
			end
			profile.aa_effectiveness.per_preset[preset_id].hits =
				profile.aa_effectiveness.per_preset[preset_id].hits + 1

			local hb = data.hitbox or "chest"
			if hb == "head" then
				profile.hitbox_distribution.head = profile.hitbox_distribution.head + 1
			elseif hb == "neck" then
				profile.hitbox_distribution.neck = profile.hitbox_distribution.neck + 1
			elseif hb == "chest" then
				profile.hitbox_distribution.chest = profile.hitbox_distribution.chest + 1
			elseif hb == "stomach" then
				profile.hitbox_distribution.stomach = profile.hitbox_distribution.stomach + 1
			elseif hb == "left leg" or hb == "right leg" then
				profile.hitbox_distribution.legs = profile.hitbox_distribution.legs + 1
			elseif hb == "left arm" or hb == "right arm" then
				profile.hitbox_distribution.arms = profile.hitbox_distribution.arms + 1
			end

			profile.hitbox_history:push({
				hitbox = hb,
				time = now,
				damage = data.damage,
			})
		else
			profile.misses:push({ time = now, preset = antiaim.my.state })
			profile.total_misses = profile.total_misses + 1

			global_stats.total_evaded = global_stats.total_evaded + 1
			global_stats.current_evasion_streak = global_stats.current_evasion_streak + 1

			if global_stats.current_evasion_streak > global_stats.best_evasion_streak then
				global_stats.best_evasion_streak = global_stats.current_evasion_streak
			end

			profile.aa_effectiveness.current_preset_misses =
				profile.aa_effectiveness.current_preset_misses + 1

			local preset_id = antiaim.my.state or "default"
			if not profile.aa_effectiveness.per_preset[preset_id] then
				profile.aa_effectiveness.per_preset[preset_id] = { hits = 0, misses = 0 }
			end
			profile.aa_effectiveness.per_preset[preset_id].misses =
				profile.aa_effectiveness.per_preset[preset_id].misses + 1
		end

		global_stats.total_shots_received = global_stats.total_shots_received + 1

		if profile.total_shots > 0 then
			profile.accuracy = profile.total_hits / profile.total_shots
		end

		local recent_hits = profile.hits:count_where(function (e)
			return (now - e.time) < 15
		end)
		local recent_shots = profile.shots:count_where(function (e)
			return (now - e.time) < 15
		end)
		if recent_shots > 0 then
			profile.recent_accuracy = recent_hits / recent_shots
		end

		local interval = now - profile.last_shot_time
		if profile.last_shot_time > 0 and interval < 8 then
			profile.timing.intervals:push(interval)

			profile.timing.avg_interval = profile.timing.intervals:weighted_average(nil, 0.85)

			if interval < profile.timing.min_interval then
				profile.timing.min_interval = interval
			end
			if interval > profile.timing.max_interval and interval < 5 then
				profile.timing.max_interval = interval
			end

			if profile.timing.avg_interval < 0.12 then
				profile.timing.is_spraying = true
				profile.timing.is_tapping = false
				profile.timing.is_bursting = false
			elseif profile.timing.avg_interval < 0.35 then
				profile.timing.is_spraying = false
				profile.timing.is_tapping = false
				profile.timing.is_bursting = true
			elseif profile.timing.avg_interval > 0.6 then
				profile.timing.is_tapping = true
				profile.timing.is_spraying = false
				profile.timing.is_bursting = false
			else
				profile.timing.is_spraying = false
				profile.timing.is_tapping = false
				profile.timing.is_bursting = false
			end

			if interval < 0.25 then
				profile.timing.burst_count = profile.timing.burst_count + 1
				if profile.timing.burst_count > profile.timing.burst_max then
					profile.timing.burst_max = profile.timing.burst_count
				end
			else
				profile.timing.burst_count = 0
			end
		end

		profile.last_shot_time = now

		local max_hb = 0
		local best_hb = "head"
		for hb, count in pairs(profile.hitbox_distribution) do
			if count > max_hb then
				max_hb = count
				best_hb = hb
			end
		end
		profile.preferred_hitbox = best_hb

		if profile.timing.avg_interval > 0.05 then
			profile.prediction.next_shot_estimate = now + profile.timing.avg_interval
			profile.prediction.confidence = math.clamp(
				1.0 - profile.timing.intervals:stddev() / (profile.timing.avg_interval + 0.01),
				0, 1
			)
		end

		if not profile.engagement.is_engaged then
			profile.engagement.is_engaged = true
			profile.engagement.start_time = now
			profile.engagement.engagement_count = profile.engagement.engagement_count + 1
		end
		profile.engagement.duration = now - profile.engagement.start_time
	end

	threat_intel.update_distance = function (entindex, distance)
		local profile = threat_intel.get_profile(entindex)
		local now = globals.realtime()

		local prev = profile.distance.current
		profile.distance.current = distance
		profile.distance.samples:push(distance)
		profile.distance.average = profile.distance.samples:weighted_average(nil, 0.9)

		if distance < profile.distance.min_ever then
			profile.distance.min_ever = distance
		end
		if distance > profile.distance.max_ever then
			profile.distance.max_ever = distance
		end

		if profile.distance.prev_time > 0 then
			local dt = now - profile.distance.prev_time
			if dt > 0 then
				profile.distance.closing_rate = (prev - distance) / dt
			end
		end

		profile.distance.prev_distance = distance
		profile.distance.prev_time = now
	end

	threat_intel.update_velocity = function (entindex, velocity)
		local profile = threat_intel.get_profile(entindex)
		local prev = profile.velocity.current
		profile.velocity.current = velocity
		profile.velocity.samples:push(velocity)
		profile.velocity.average = profile.velocity.samples:weighted_average(nil, 0.9)

		if velocity > profile.velocity.max_seen then
			profile.velocity.max_seen = velocity
		end

		local was_slow = prev < 50
		local is_fast = velocity > 150

		if was_slow and is_fast then
			profile.velocity.is_peeking = true
			profile.velocity.peek_count = profile.velocity.peek_count + 1
			profile.velocity.peek_timestamps:push(globals.realtime())
		elseif velocity < 10 then
			profile.velocity.is_peeking = false
		end

		profile.velocity.was_slow = velocity < 50

		if profile.velocity.samples.count >= 4 then
			local variance = profile.velocity.samples:variance()
			if variance > 5000 and profile.velocity.average < 100 then
				profile.flags.is_jiggle_peeking = true
			else
				profile.flags.is_jiggle_peeking = false
			end
		end
	end

	threat_intel.update_position = function (entindex, origin)
		local profile = threat_intel.get_profile(entindex)
		local now = globals.realtime()

		profile.position.previous = profile.position.current
		profile.position.current = origin

		if profile.position.last_update > 0 and my.valid then
			local dt = now - profile.position.last_update
			if dt > 0 then
				local diff = origin - profile.position.previous
				local dir_to_me = my.origin - origin
				local dot = diff.x * dir_to_me.x + diff.y * dir_to_me.y
				local move_len = diff:length2d()
				local dir_len = dir_to_me:length2d()

				if move_len > 1 and dir_len > 1 then
					local cos_angle = dot / (move_len * dir_len)

					if cos_angle > 0.5 then
						profile.flags.is_pushing = true
						profile.flags.is_retreating = false
					elseif cos_angle < -0.5 then
						profile.flags.is_retreating = true
						profile.flags.is_pushing = false
					else
						profile.flags.is_pushing = false
						profile.flags.is_retreating = false
						if move_len > 50 then
							profile.flags.is_flanking = true
						end
					end
				end
			end
		end

		profile.position.last_update = now
	end

	threat_intel.update_angles = function (entindex)
		local profile = threat_intel.get_profile(entindex)

		local eye_yaw = select(2, entity.get_prop(entindex, "m_angEyeAngles")) or 0
		local eye_pitch = entity.get_prop(entindex, "m_angEyeAngles") or 0

		profile.angles.prev_eye_yaw = profile.angles.eye_yaw
		profile.angles.eye_yaw = eye_yaw
		profile.angles.eye_pitch = eye_pitch

		profile.angles.yaw_delta = math.angle_diff(eye_yaw, profile.angles.prev_eye_yaw)
		profile.angles.yaw_deltas:push(math.abs(profile.angles.yaw_delta))

		if profile.angles.yaw_deltas.count >= 4 then
			profile.angles.aim_stability = 1 - math.clamp(
				profile.angles.yaw_deltas:average() / 30,
				0, 1
			)
		end

		if my.valid then
			local my_origin = my.origin
			local their_origin = profile.position.current
			if their_origin and their_origin:length() > 0 then
				local diff = my_origin - their_origin
				local angle_to_me = math.deg(math.atan2(diff.y, diff.x))
				local angle_diff = math.abs(math.angle_diff(eye_yaw, angle_to_me))

				profile.angles.looking_at_me = angle_diff < 30

				if profile.angles.looking_at_me then
					profile.time_targeting_me = profile.time_targeting_me + globals.absoluteframetime()
				end
			end
		end
	end

	threat_intel.compute_threat_score = function (entindex)
		local profile = threat_intel.get_profile(entindex)
		local now = globals.realtime()

		local recency = math.exp(-0.5 * (now - profile.last_shot_time))

		local dist = profile.distance.current
		local distance_score
		if dist < 150 then distance_score = 1.0
		elseif dist < 400 then distance_score = math.remap(dist, 150, 400, 1.0, 0.8)
		elseif dist < 800 then distance_score = math.remap(dist, 400, 800, 0.8, 0.5)
		elseif dist < 1500 then distance_score = math.remap(dist, 800, 1500, 0.5, 0.3)
		elseif dist < 2500 then distance_score = math.remap(dist, 1500, 2500, 0.3, 0.1)
		else distance_score = 0.05 end

		if profile.distance.closing_rate > 100 then
			distance_score = distance_score * 1.2
		end

		local accuracy_score = math.lerp(profile.accuracy, profile.recent_accuracy, 0.6) * 1.5

		local frequency_score = 0
		if profile.timing.avg_interval > 0 then
			frequency_score = math.clamp(1.0 / (profile.timing.avg_interval + 0.1) * 0.25, 0, 1)
		end

		local weapon_score = 0.5
		if profile.weapon_class == "awp" then weapon_score = 1.0
		elseif profile.weapon_class == "auto" then weapon_score = 0.95
		elseif profile.weapon_class == "scout" then weapon_score = 0.85
		elseif profile.weapon_class == "sniper" then weapon_score = 0.9
		elseif profile.weapon_class == "rifle" then weapon_score = 0.7
		elseif profile.weapon_class == "smg" then weapon_score = 0.4
		elseif profile.weapon_class == "pistol" then weapon_score = 0.5
		elseif profile.weapon_class == "shotgun" then weapon_score = 0.6
		elseif profile.weapon_class == "knife" then weapon_score = 0.8
		elseif profile.weapon_class == "grenade" then weapon_score = 0.1 end

		local behavior_score = 0
		if profile.velocity.is_peeking then behavior_score = behavior_score + 0.25 end
		if profile.timing.is_spraying then behavior_score = behavior_score + 0.15 end
		if profile.timing.burst_count > 3 then behavior_score = behavior_score + 0.15 end
		if profile.flags.is_pushing then behavior_score = behavior_score + 0.2 end
		if profile.flags.is_jiggle_peeking then behavior_score = behavior_score + 0.15 end
		if profile.flags.is_flanking then behavior_score = behavior_score + 0.1 end
		behavior_score = math.clamp(behavior_score, 0, 1)

		local aim_score = 0
		if profile.angles.looking_at_me then aim_score = aim_score + 0.5 end
		aim_score = aim_score + profile.angles.aim_stability * 0.3
		if profile.time_targeting_me > 2 then aim_score = aim_score + 0.2 end
		aim_score = math.clamp(aim_score, 0, 1)

		local consistency_score = 0
		if profile.total_shots >= 3 then
			local interval_consistency = 1 - math.clamp(
				profile.timing.intervals:stddev() / (profile.timing.avg_interval + 0.01),
				0, 1
			)
			consistency_score = interval_consistency * 0.5 + profile.accuracy * 0.5
		end

		profile.score_components.distance_score = distance_score
		profile.score_components.accuracy_score = accuracy_score
		profile.score_components.frequency_score = frequency_score
		profile.score_components.weapon_score = weapon_score
		profile.score_components.behavior_score = behavior_score
		profile.score_components.aim_score = aim_score
		profile.score_components.recency_score = recency
		profile.score_components.consistency_score = consistency_score

		local weights = {
			distance = 0.20,
			accuracy = 0.18,
			frequency = 0.12,
			weapon = 0.12,
			behavior = 0.10,
			aim = 0.10,
			recency = 0.08,
			consistency = 0.10,
		}

		profile.threat_score =
			distance_score * weights.distance +
			accuracy_score * weights.accuracy +
			frequency_score * weights.frequency +
			weapon_score * weights.weapon +
			behavior_score * weights.behavior +
			aim_score * weights.aim +
			recency * weights.recency +
			consistency_score * weights.consistency

		profile.threat_score = math.clamp(profile.threat_score, 0, 1)

		if profile.threat_score > 0.75 then profile.danger_level = 4
		elseif profile.threat_score > 0.55 then profile.danger_level = 3
		elseif profile.threat_score > 0.35 then profile.danger_level = 2
		elseif profile.threat_score > 0.15 then profile.danger_level = 1
		else profile.danger_level = 0 end

		profile.flags.is_aggressive =
			profile.timing.avg_interval < 0.3
			and profile.total_shots > 3
			and not profile.flags.is_retreating

		profile.flags.is_holding =
			profile.velocity.current < 10
			and profile.timing.is_tapping
			and profile.angles.aim_stability > 0.7

		profile.flags.is_rotating =
			profile.velocity.is_peeking
			and profile.velocity.peek_count > 2
			and profile.flags.is_flanking

		profile.flags.is_baiting =
			profile.distance.closing_rate < -50
			and profile.angles.looking_at_me
			and profile.velocity.current > 100

		if profile.engagement.is_engaged and (now - profile.last_shot_time > 3) then
			profile.engagement.is_engaged = false
		end

		return profile.threat_score
	end

	threat_intel.get_primary_threat = function ()
		local best_ent, best_score = nil, 0

		for ent, profile in pairs(player_profiles) do
			local alive = pcall(entity.is_alive, ent) and entity.is_alive(ent)
			if alive and not entity.is_dormant(ent) then
				local score = threat_intel.compute_threat_score(ent)
				if score > best_score then
					best_ent = ent
					best_score = score
				end
			end
		end

		return best_ent, best_score
	end

	threat_intel.get_active_threats = function (min_score)
		min_score = min_score or 0.1
		local threats = {}

		for ent, profile in pairs(player_profiles) do
			local alive = pcall(entity.is_alive, ent) and entity.is_alive(ent)
			if alive and not entity.is_dormant(ent) then
				local score = threat_intel.compute_threat_score(ent)
				if score >= min_score then
					threats[#threats+1] = {
						entindex = ent,
						profile = profile,
						score = score,
					}
				end
			end
		end

		table.sort(threats, function (a, b) return a.score > b.score end)
		return threats
	end

	threat_intel.get_threat_count = function (min_danger)
		min_danger = min_danger or 1
		local count = 0
		for ent, profile in pairs(player_profiles) do
			if profile.danger_level >= min_danger then
				local alive = pcall(entity.is_alive, ent) and entity.is_alive(ent)
				if alive then count = count + 1 end
			end
		end
		return count
	end

	threat_intel.get_global_stats = function ()
		return global_stats
	end

	threat_intel.get_evasion_rate = function ()
		if global_stats.total_shots_received == 0 then return 1 end
		return global_stats.total_evaded / global_stats.total_shots_received
	end

	threat_intel.get_recent_evasion_rate = function (window)
		window = window or 15
		local now = globals.realtime()
		local recent_evaded = 0
		local recent_total = 0

		for ent, profile in pairs(player_profiles) do
			recent_evaded = recent_evaded + profile.misses:count_where(function (e)
				return (now - e.time) < window
			end)
			recent_total = recent_total + profile.shots:count_where(function (e)
				return (now - e.time) < window
			end)
		end

		if recent_total == 0 then return 1 end
		return recent_evaded / recent_total
	end

	threat_intel.get_damage_per_second = function (window)
		window = window or 10
		local now = globals.realtime()
		local total_dmg = 0

		for i, entry in global_stats.hp_lost_history:iterate() do
			if (now - entry.time) < window then
				total_dmg = total_dmg + entry.damage
			end
		end

		return total_dmg / window
	end

	threat_intel.get_worst_preset = function (entindex)
		local profile = threat_intel.get_profile(entindex)
		local worst_preset, worst_ratio = nil, -1

		for preset_id, data in pairs(profile.aa_effectiveness.per_preset) do
			local total = data.hits + data.misses
			if total >= 2 then
				local hit_ratio = data.hits / total
				if hit_ratio > worst_ratio then
					worst_ratio = hit_ratio
					worst_preset = preset_id
				end
			end
		end

		return worst_preset, worst_ratio
	end

	threat_intel.predict_next_shot = function (entindex)
		local profile = threat_intel.get_profile(entindex)
		return profile.prediction.next_shot_estimate,
			profile.prediction.confidence
	end

	threat_intel.reset_round = function ()
		global_stats.round_number = global_stats.round_number + 1
		global_stats.damage_taken_round = 0

		for ent, profile in pairs(player_profiles) do
			profile.timing.burst_count = 0
			profile.velocity.is_peeking = false
			profile.aa_effectiveness.current_preset_hits = 0
			profile.aa_effectiveness.current_preset_misses = 0
			profile.engagement.is_engaged = false
			profile.engagement.duration = 0
			profile.flags.is_flanking = false
			profile.flags.is_pushing = false
			profile.flags.is_retreating = false
			profile.flags.is_baiting = false
			profile.time_targeting_me = 0
		end
	end

	threat_intel.cleanup = function ()
		local now = globals.realtime()
		local to_remove = {}

		for ent, profile in pairs(player_profiles) do
			local alive = pcall(entity.is_alive, ent) and entity.is_alive(ent)
			local dormant = pcall(entity.is_dormant, ent) and entity.is_dormant(ent)
			if not alive or dormant or (now - profile.last_seen > 30) then
				to_remove[#to_remove+1] = ent
			end
		end

		for _, ent in ipairs(to_remove) do
			threat_intel.remove_profile(ent)
		end
	end

	threat_intel.reset_all = function ()
		for ent in pairs(player_profiles) do
			threat_intel.remove_profile(ent)
		end
		player_profiles = {}
		global_stats.total_shots_received = 0
		global_stats.total_evaded = 0
		global_stats.total_hit = 0
		global_stats.current_evasion_streak = 0
		global_stats.damage_taken_total = 0
		global_stats.damage_taken_round = 0
		global_stats.hp_lost_history:clear()
	end

	timer_system.create(5, 0, function ()
		threat_intel.cleanup()
	end)

	callbacks.round_start:set(function ()
		threat_intel.reset_round()
	end)

	callbacks.net_update_end:set(function ()
		if not my.valid then return end

		for i = 1, #players do
			local ent = players[i]
			if not entity.is_enemy(ent) then goto continue_player end
			if entity.is_dormant(ent) then goto continue_player end

			local origin_raw = {entity.get_prop(ent, "m_vecOrigin")}
			if not origin_raw[1] then goto continue_player end

			local origin = vector(origin_raw[1], origin_raw[2], origin_raw[3])
			local dist = my.origin:dist(origin)

			threat_intel.update_distance(ent, dist)

			local vel = entity.get_velocity_2d(ent)
			threat_intel.update_velocity(ent, vel)

			threat_intel.update_position(ent, origin)
			threat_intel.update_angles(ent)

			local weapon = entity.get_player_weapon(ent)
			if weapon then
				local profile = threat_intel.get_profile(ent)
				threat_intel.classify_weapon(profile, weapon)
			end

			::continue_player::
		end
	end)
end

-- #endregion


-- #region - Anti-Brute System

local antibrute = {} do
	antibrute.__index = antibrute

	local PHASE_COUNT = 8
	local ROTATION_THRESHOLD = 2
	local EMERGENCY_THRESHOLD = 4
	local COOLDOWN_TIME = 0.7
	local DECAY_TIME = 10.0
	local MAX_ROTATIONS_PER_ROUND = 20
	local PHASE_EVALUATION_WINDOW = 30

	local ab_state = {
		active = false,
		phase = 0,
		side_index = 0,
		last_rotation = 0,
		consecutive_hits = 0,
		consecutive_misses = 0,
		total_rotations = 0,
		round_rotations = 0,

		per_attacker = {},
		rotation_history = ring_buffer.new(48),
		effectiveness = ring_buffer.new(96),
		phase_performance = {},

		current_adjustments = {
			yaw_offset = 0,
			body_offset = 0,
			pitch_adjust = 0,
			modifier_scale = 1,
			jitter_override = 0,
		},

		sm = state_machine.new("idle"),

		adaptive = {
			rotation_speed = 1.0,
			aggression = 0.5,
			last_effective_phase = 0,
			phase_blacklist = {},
			blacklist_duration = 15,
		},
	}

	for p = 0, PHASE_COUNT - 1 do
		ab_state.phase_performance[p] = {
			hits = 0,
			misses = 0,
			total = 0,
			score = 0.5,
			last_used = 0,
			time_in_phase = 0,
		}
	end

	ab_state.sm:add_state("idle", {
		on_enter = function (sm)
			ab_state.phase = 0
			ab_state.consecutive_hits = 0
			ab_state.consecutive_misses = 0
		end
	})

	ab_state.sm:add_state("alert", {
		on_enter = function (sm)
			debug("Anti-brute: alert state entered")
		end,
		on_update = function (sm, dt)
			if sm:time() > 5 and ab_state.consecutive_hits == 0 then
				sm:transition("monitoring")
			end
		end
	})

	ab_state.sm:add_state("monitoring", {
		on_enter = function (sm)
			ab_state.consecutive_misses = 0
		end,
		on_update = function (sm, dt)
			if sm:time() > DECAY_TIME and ab_state.consecutive_hits == 0 then
				sm:transition("idle")
			end

			ab_state.phase_performance[ab_state.phase].time_in_phase =
				ab_state.phase_performance[ab_state.phase].time_in_phase + dt
		end
	})

	ab_state.sm:add_state("rotating", {
		on_enter = function (sm, prev)
			ab_state.total_rotations = ab_state.total_rotations + 1
			ab_state.round_rotations = ab_state.round_rotations + 1
			ab_state.last_rotation = globals.realtime()

			ab_state.rotation_history:push({
				time = globals.realtime(),
				phase_from = prev == "monitoring" and ab_state.phase or -1,
				phase_to = ab_state.phase,
				from_hits = ab_state.consecutive_hits,
				trigger = "normal",
			})

			ab_state.consecutive_hits = 0
			ab_state.consecutive_misses = 0

			debug("Anti-brute: rotating to phase ", ab_state.phase)
		end,
		on_update = function (sm, dt)
			if sm:time() > COOLDOWN_TIME then
				sm:transition("monitoring")
			end
		end
	})

	ab_state.sm:add_state("emergency", {
		on_enter = function (sm, prev)
			ab_state.total_rotations = ab_state.total_rotations + 1
			ab_state.round_rotations = ab_state.round_rotations + 1
			ab_state.last_rotation = globals.realtime()

			ab_state.rotation_history:push({
				time = globals.realtime(),
				phase_from = ab_state.phase,
				phase_to = (ab_state.phase + 3) % PHASE_COUNT,
				from_hits = ab_state.consecutive_hits,
				trigger = "emergency",
			})

			ab_state.phase = (ab_state.phase + 3) % PHASE_COUNT
			ab_state.consecutive_hits = 0
			ab_state.consecutive_misses = 0

			debug("Anti-brute: EMERGENCY rotate to phase ", ab_state.phase)
		end,
		on_update = function (sm, dt)
			if sm:time() > COOLDOWN_TIME * 2 then
				sm:transition("monitoring")
			end
		end
	})

	ab_state.sm:add_state("lockdown", {
		on_enter = function (sm)
			debug("Anti-brute: lockdown (max rotations reached)")
		end,
		on_update = function (sm, dt)
			if sm:time() > 15 then
				ab_state.round_rotations = math.floor(ab_state.round_rotations * 0.5)
				sm:transition("monitoring")
			end
		end
	})

	ab_state.sm:add_transition("idle", "alert", function ()
		return ab_state.active
	end)

	ab_state.sm:add_transition("alert", "monitoring", function (sm)
		return sm:time() > 1
	end)

	ab_state.sm:add_transition("monitoring", "rotating", function ()
		return ab_state.consecutive_hits >= ROTATION_THRESHOLD
			and ab_state.round_rotations < MAX_ROTATIONS_PER_ROUND
	end)

	ab_state.sm:add_transition("monitoring", "emergency", function ()
		return ab_state.consecutive_hits >= EMERGENCY_THRESHOLD
	end)

	ab_state.sm:add_transition("rotating", "emergency", function (sm)
		return ab_state.consecutive_hits >= 1 and sm:time() < COOLDOWN_TIME
	end)

	ab_state.sm:add_transition("monitoring", "lockdown", function ()
		return ab_state.round_rotations >= MAX_ROTATIONS_PER_ROUND
	end)

	ab_state.sm:add_transition("rotating", "lockdown", function ()
		return ab_state.round_rotations >= MAX_ROTATIONS_PER_ROUND
	end)

	local phase_adjustments = {
		[0] = { yaw = 0,    body = 0,    pitch = 0,   scale = 1.0, jitter = 0 },
		[1] = { yaw = 25,   body = -58,  pitch = 0,   scale = 0.85, jitter = 5 },
		[2] = { yaw = -25,  body = 58,   pitch = 0,   scale = 0.85, jitter = -5 },
		[3] = { yaw = 40,   body = -120, pitch = 4,   scale = 0.65, jitter = 10 },
		[4] = { yaw = -40,  body = 120,  pitch = -4,  scale = 0.65, jitter = -10 },
		[5] = { yaw = 15,   body = -30,  pitch = 8,   scale = 0.75, jitter = 15 },
		[6] = { yaw = -15,  body = 30,   pitch = -8,  scale = 0.75, jitter = -15 },
		[7] = { yaw = 0,    body = 0,    pitch = 0,   scale = 0.5,  jitter = 20 },
	}

	local function get_attacker_state(entindex)
		if not ab_state.per_attacker[entindex] then
			ab_state.per_attacker[entindex] = {
				shots = 0,
				hits = 0,
				misses = 0,
				last_phase_on_hit = -1,
				rotations_caused = 0,
				pattern = ring_buffer.new(24),
				phases_hit_on = {},
				consecutive_at_me = 0,
				last_shot_time = 0,
			}
		end
		return ab_state.per_attacker[entindex]
	end

	local function find_best_phase()
		local now = globals.realtime()
		local best_phase = 0
		local best_score = -1
		local blacklist = ab_state.adaptive.phase_blacklist

		for p = 0, PHASE_COUNT - 1 do
			if p == ab_state.phase then goto next_phase end

			if blacklist[p] and (now - blacklist[p]) < ab_state.adaptive.blacklist_duration then
				goto next_phase
			end

			local perf = ab_state.phase_performance[p]
			local score

			if perf.total == 0 then
				score = 0.7
			else
				local miss_ratio = perf.misses / perf.total
				local recency = math.exp(-0.1 * (now - perf.last_used))
				local freshness = 1 - recency
				score = miss_ratio * 0.6 + freshness * 0.4
			end

			if score > best_score then
				best_score = score
				best_phase = p
			end

			::next_phase::
		end

		return best_phase
	end

	antibrute.on_hit = function (attacker, hitgroup, damage)
		ab_state.active = true
		ab_state.consecutive_hits = ab_state.consecutive_hits + 1
		ab_state.consecutive_misses = 0

		local att = get_attacker_state(attacker)
		att.shots = att.shots + 1
		att.hits = att.hits + 1
		att.last_phase_on_hit = ab_state.phase
		att.consecutive_at_me = att.consecutive_at_me + 1
		att.last_shot_time = globals.realtime()

		if not att.phases_hit_on[ab_state.phase] then
			att.phases_hit_on[ab_state.phase] = 0
		end
		att.phases_hit_on[ab_state.phase] = att.phases_hit_on[ab_state.phase] + 1

		att.pattern:push({
			time = globals.realtime(),
			type = "hit",
			phase = ab_state.phase,
			hitgroup = hitgroup,
			damage = damage,
		})

		ab_state.effectiveness:push({
			time = globals.realtime(),
			phase = ab_state.phase,
			result = "hit",
			attacker = attacker,
			damage = damage,
		})

		ab_state.phase_performance[ab_state.phase].hits =
			ab_state.phase_performance[ab_state.phase].hits + 1
		ab_state.phase_performance[ab_state.phase].total =
			ab_state.phase_performance[ab_state.phase].total + 1

		threat_intel.record_shot(attacker, {
			hit = true,
			hitbox = enums.hitgroups[(hitgroup or 0) + 1],
			damage = damage,
			distance = threat_intel.get_profile(attacker).distance.current,
		})

		if ab_state.consecutive_hits >= ROTATION_THRESHOLD then
			antibrute.rotate()
		end

		if ab_state.consecutive_hits >= 3 then
			ab_state.adaptive.phase_blacklist[ab_state.phase] = globals.realtime()
		end

		antiaim.signals.on_defensive:emit({
			type = "brute_hit",
			attacker = attacker,
			phase = ab_state.phase,
			consecutive = ab_state.consecutive_hits,
			damage = damage,
		})
	end

	antibrute.on_miss = function (attacker)
		ab_state.active = true
		ab_state.consecutive_misses = ab_state.consecutive_misses + 1

		if ab_state.consecutive_hits > 0 then
			ab_state.consecutive_hits = ab_state.consecutive_hits - 1
		end

		local att = get_attacker_state(attacker)
		att.shots = att.shots + 1
		att.misses = att.misses + 1
		att.consecutive_at_me = 0
		att.last_shot_time = globals.realtime()

		att.pattern:push({
			time = globals.realtime(),
			type = "miss",
			phase = ab_state.phase,
		})

		ab_state.effectiveness:push({
			time = globals.realtime(),
			phase = ab_state.phase,
			result = "miss",
			attacker = attacker,
		})

		ab_state.phase_performance[ab_state.phase].misses =
			ab_state.phase_performance[ab_state.phase].misses + 1
		ab_state.phase_performance[ab_state.phase].total =
			ab_state.phase_performance[ab_state.phase].total + 1

		if ab_state.consecutive_misses >= 5 then
			ab_state.adaptive.last_effective_phase = ab_state.phase
		end

		threat_intel.record_shot(attacker, {
			hit = false,
			distance = threat_intel.get_profile(attacker).distance.current,
		})
	end

	antibrute.rotate = function ()
		local now = globals.realtime()
		if now - ab_state.last_rotation < COOLDOWN_TIME then return end
		if ab_state.round_rotations >= MAX_ROTATIONS_PER_ROUND then return end

		local old_phase = ab_state.phase
		ab_state.phase_performance[old_phase].last_used = now

		ab_state.phase = find_best_phase()

		local adj = phase_adjustments[ab_state.phase]
		ab_state.current_adjustments.yaw_offset = adj.yaw
		ab_state.current_adjustments.body_offset = adj.body
		ab_state.current_adjustments.pitch_adjust = adj.pitch
		ab_state.current_adjustments.modifier_scale = adj.scale
		ab_state.current_adjustments.jitter_override = adj.jitter

		ab_state.sm:transition("rotating", true)

		debug("Anti-brute: phase ", old_phase, " -> ", ab_state.phase,
			" (score: ", string.format("%.2f", ab_state.phase_performance[ab_state.phase].score or 0), ")")
	end

	antibrute.get_adjustments = function ()
		if not ab_state.active then
			return {
				yaw_offset = 0,
				body_offset = 0,
				pitch_adjust = 0,
				modifier_scale = 1,
				jitter_override = 0,
			}
		end

		local now = globals.realtime()
		local time_since = now - ab_state.last_rotation

		if time_since > DECAY_TIME * 2 then
			ab_state.active = false
			ab_state.phase = 0
			ab_state.current_adjustments.yaw_offset = 0
			ab_state.current_adjustments.body_offset = 0
			ab_state.current_adjustments.pitch_adjust = 0
			ab_state.current_adjustments.modifier_scale = 1
			ab_state.current_adjustments.jitter_override = 0
			return ab_state.current_adjustments
		end

		local decay = math.smoothstep(0, DECAY_TIME, time_since)
		local inv_decay = 1 - decay

		return {
			yaw_offset = ab_state.current_adjustments.yaw_offset * inv_decay,
			body_offset = ab_state.current_adjustments.body_offset * inv_decay,
			pitch_adjust = ab_state.current_adjustments.pitch_adjust * inv_decay,
			modifier_scale = math.lerp(ab_state.current_adjustments.modifier_scale, 1, decay),
			jitter_override = ab_state.current_adjustments.jitter_override * inv_decay,
		}
	end

	antibrute.get_phase = function ()
		return ab_state.phase
	end

	antibrute.get_state = function ()
		return ab_state.sm.current
	end

	antibrute.is_active = function ()
		return ab_state.active
	end

	antibrute.get_total_rotations = function ()
		return ab_state.total_rotations
	end

	antibrute.get_round_rotations = function ()
		return ab_state.round_rotations
	end

	antibrute.get_phase_stats = function (phase)
		return ab_state.phase_performance[phase or ab_state.phase]
	end

	antibrute.get_effectiveness = function ()
		if ab_state.effectiveness.count == 0 then return 1 end
		local now = globals.realtime()

		local recent_misses = ab_state.effectiveness:count_where(function (e)
			return e.result == "miss" and (now - e.time) < PHASE_EVALUATION_WINDOW
		end)
		local recent_total = ab_state.effectiveness:count_where(function (e)
			return (now - e.time) < PHASE_EVALUATION_WINDOW
		end)

		if recent_total == 0 then return 1 end
		return recent_misses / recent_total
	end

	antibrute.get_attacker_info = function (entindex)
		return ab_state.per_attacker[entindex]
	end

	antibrute.reset = function ()
		ab_state.active = false
		ab_state.phase = 0
		ab_state.side_index = 0
		ab_state.consecutive_hits = 0
		ab_state.consecutive_misses = 0
		ab_state.round_rotations = 0
		ab_state.last_rotation = 0
		ab_state.per_attacker = {}
		ab_state.rotation_history:clear()
		ab_state.effectiveness:clear()
		ab_state.adaptive.phase_blacklist = {}

		for p = 0, PHASE_COUNT - 1 do
			ab_state.phase_performance[p].hits = 0
			ab_state.phase_performance[p].misses = 0
			ab_state.phase_performance[p].total = 0
			ab_state.phase_performance[p].score = 0.5
			ab_state.phase_performance[p].last_used = 0
			ab_state.phase_performance[p].time_in_phase = 0
		end

		ab_state.current_adjustments.yaw_offset = 0
		ab_state.current_adjustments.body_offset = 0
		ab_state.current_adjustments.pitch_adjust = 0
		ab_state.current_adjustments.modifier_scale = 1
		ab_state.current_adjustments.jitter_override = 0
		ab_state.sm:transition("idle", true)
	end

	antibrute.update = function ()
		ab_state.sm:update(globals.absoluteframetime())

		local now = globals.realtime()
		for p = 0, PHASE_COUNT - 1 do
			local perf = ab_state.phase_performance[p]
			if perf.total > 0 then
				perf.score = perf.misses / perf.total
			end
		end

		local bl = ab_state.adaptive.phase_blacklist
		for p, t in pairs(bl) do
			if (now - t) > ab_state.adaptive.blacklist_duration then
				bl[p] = nil
			end
		end
	end

	callbacks.round_start:set(function ()
		antibrute.reset()
	end)

	callbacks.setup_command:set(function ()
		if ab_state.active then
			antibrute.update()
		end
	end)
end

-- #endregion


-- #region - Confidence Scoring System

local confidence = {} do
	local scoring = {
		current = 0.5,
		target = 0.5,
		velocity = 0,
		raw = 0.5,

		history = ring_buffer.new(256),
		preset_scores = {},
		component_history = ring_buffer.new(64),

		weights = {
			evasion_rate = 0.25,
			recent_evasion = 0.15,
			entropy = 0.10,
			threat_spread = 0.08,
			brute_effectiveness = 0.15,
			time_alive = 0.05,
			preset_performance = 0.12,
			damage_rate = 0.10,
		},

		thresholds = {
			critical = 0.20,
			low = 0.35,
			medium = 0.55,
			high = 0.72,
			excellent = 0.88,
		},

		adaptive_weights = {
			enabled = true,
			learning_rate = 0.02,
			history_window = 60,
		},
	}

	confidence.compute = function ()
		local components = {}
		local now = globals.realtime()

		components.evasion_rate = threat_intel.get_evasion_rate()
		components.recent_evasion = threat_intel.get_recent_evasion_rate(10)

		local entropy = antiaim.my.entropy or 0
		local norm_entropy = math.clamp(entropy / 30, 0, 1)
		components.entropy = norm_entropy > 0.1 and norm_entropy or 0.3

		local threats = threat_intel.get_active_threats(0.1)
		local threat_count = #threats
		components.threat_spread = threat_count > 0
			and math.clamp(1 - (threat_count - 1) * 0.12, 0.2, 1)
			or 1.0

		components.brute_effectiveness = antibrute.get_effectiveness()

		local dps = threat_intel.get_damage_per_second(8)
		components.damage_rate = math.clamp(1 - dps / 20, 0, 1)

		local alive_time = 0
		if my.valid then
			local gstats = threat_intel.get_global_stats()
			alive_time = math.clamp(
				(now - (gstats.session_start or now)) / 120,
				0, 1
			)
		end
		components.time_alive = alive_time

		local preset_id = antiaim.my.state or "default"
		local ps = scoring.preset_scores[preset_id]
		if ps and ps.total > 0 then
			local recent_miss_rate = 0.5
			if ps.recent.count > 3 then
				local recent_misses = ps.recent:count_where(function (e)
					return not e.hit and (now - e.time) < 30
				end)
				local recent_total = ps.recent:count_where(function (e)
					return (now - e.time) < 30
				end)
				if recent_total > 0 then
					recent_miss_rate = recent_misses / recent_total
				end
			end
			components.preset_performance = math.lerp(
				ps.misses / ps.total,
				recent_miss_rate,
				0.6
			)
		else
			components.preset_performance = 0.5
		end

		scoring.component_history:push({
			time = now,
			components = table.copy(components),
		})

		local score = 0
		local weight_total = 0
		for key, weight in pairs(scoring.weights) do
			local value = components[key]
			if value then
				score = score + value * weight
				weight_total = weight_total + weight
			end
		end
		if weight_total > 0 then
			score = score / weight_total
		end

		scoring.raw = score
		scoring.target = math.clamp(score, 0, 1)

		local spring_stiffness = 40
		local spring_damping = 8

		scoring.current, scoring.velocity = math.damped_spring(
			scoring.current,
			scoring.target,
			scoring.velocity,
			spring_damping,
			spring_stiffness,
			globals.absoluteframetime()
		)
		scoring.current = math.clamp(scoring.current, 0, 1)

		scoring.history:push({
			time = now,
			score = scoring.current,
			target = scoring.target,
			raw = scoring.raw,
			preset = preset_id,
			phase = antibrute.get_phase(),
		})

		return scoring.current
	end

	confidence.get = function ()
		return scoring.current
	end

	confidence.get_raw = function ()
		return scoring.raw
	end

	confidence.get_target = function ()
		return scoring.target
	end

	confidence.get_level = function ()
		local s = scoring.current
		if s >= scoring.thresholds.excellent then return "excellent", 5
		elseif s >= scoring.thresholds.high then return "high", 4
		elseif s >= scoring.thresholds.medium then return "medium", 3
		elseif s >= scoring.thresholds.low then return "low", 2
		elseif s >= scoring.thresholds.critical then return "critical", 1
		else return "failing", 0 end
	end

	confidence.get_trend = function (window)
		window = window or 10
		if scoring.history.count < 4 then return 0 end

		local now = globals.realtime()
		local old_sum, old_count = 0, 0
		local new_sum, new_count = 0, 0
		local midpoint = now - window * 0.5

		for i, entry in scoring.history:iterate() do
			if (now - entry.time) > window then goto skip end
			if entry.time < midpoint then
				old_sum = old_sum + entry.score
				old_count = old_count + 1
			else
				new_sum = new_sum + entry.score
				new_count = new_count + 1
			end
			::skip::
		end

		if old_count == 0 or new_count == 0 then return 0 end

		local old_avg = old_sum / old_count
		local new_avg = new_sum / new_count

		return new_avg - old_avg
	end

	confidence.record_preset_result = function (preset_id, hit)
		if not scoring.preset_scores[preset_id] then
			scoring.preset_scores[preset_id] = {
				hits = 0,
				misses = 0,
				total = 0,
				recent = ring_buffer.new(48),
				streak = 0,
				best_streak = 0,
			}
		end

		local ps = scoring.preset_scores[preset_id]
		ps.total = ps.total + 1

		if hit then
			ps.hits = ps.hits + 1
			ps.streak = 0
		else
			ps.misses = ps.misses + 1
			ps.streak = ps.streak + 1
			if ps.streak > ps.best_streak then
				ps.best_streak = ps.streak
			end
		end

		ps.recent:push({
			hit = hit,
			time = globals.realtime(),
		})
	end

	confidence.get_preset_score = function (preset_id)
		local ps = scoring.preset_scores[preset_id]
		if not ps or ps.total == 0 then return 0.5 end

		local now = globals.realtime()
		if ps.recent.count > 5 then
			local recent_misses = ps.recent:count_where(function (e)
				return not e.hit and (now - e.time) < 30
			end)
			local recent_total = ps.recent:count_where(function (e)
				return (now - e.time) < 30
			end)
			if recent_total > 0 then
				return recent_misses / recent_total
			end
		end

		return ps.misses / ps.total
	end

	confidence.get_best_preset = function ()
		local best_id, best_score = nil, -1

		for id, ps in pairs(scoring.preset_scores) do
			if ps.total >= 3 then
				local score = confidence.get_preset_score(id)
				if score > best_score then
					best_score = score
					best_id = id
				end
			end
		end

		return best_id, best_score
	end

	confidence.should_override_safe = function ()
		local level_name, level = confidence.get_level()
		return level <= 1
	end

	confidence.should_override_body = function ()
		local level_name, level = confidence.get_level()
		return level <= 2
	end

	confidence.is_declining = function ()
		return confidence.get_trend(8) < -0.05
	end

	confidence.is_improving = function ()
		return confidence.get_trend(8) > 0.05
	end

	confidence.reset = function ()
		scoring.current = 0.5
		scoring.target = 0.5
		scoring.velocity = 0
		scoring.raw = 0.5
		scoring.history:clear()
		scoring.preset_scores = {}
		scoring.component_history:clear()
	end

	callbacks.round_start:set(function ()
		scoring.current = 0.5
		scoring.target = 0.5
		scoring.velocity = 0
	end)

	timer_system.create(0.5, 0, function ()
		if my.valid then
			confidence.compute()
		end
	end)
end

-- #endregion


-- #region - AA Self-Analytics

local aa_analytics = {} do
	local analytics_data = {
		pattern_detector = {
			yaw_history = ring_buffer.new(96),
			body_history = ring_buffer.new(96),
			switch_history = ring_buffer.new(48),
			combined_history = ring_buffer.new(64),
			last_analysis = 0,
			analysis_interval = 1.5,
			analysis_count = 0,
		},

		self_analysis = {
			predictability = 0,
			yaw_variance = 0,
			body_variance = 0,
			yaw_stddev = 0,
			body_stddev = 0,
			switch_regularity = 0,
			effective_range = 0,
			autocorrelation = 0,
			periodicity = 0,
			symmetry = 0,
			coverage = 0,
		},

		recommendations = {
			increase_entropy = false,
			change_modifier = false,
			adjust_delay = false,
			rotate_preset = false,
			widen_range = false,
			break_symmetry = false,
			reason = "",
			priority = 0,
		},

		performance = {
			total_analyses = 0,
			avg_analysis_time = 0,
			analysis_times = ring_buffer.new(16),
		},
	}

	aa_analytics.record = function (yaw, body, switch)
		local pd = analytics_data.pattern_detector
		pd.yaw_history:push(yaw or 0)
		pd.body_history:push(body or 0)
		if switch ~= nil then
			pd.switch_history:push(switch and 1 or 0)
		end
		pd.combined_history:push({
			yaw = yaw or 0,
			body = body or 0,
			switch = switch,
			time = globals.realtime(),
		})
	end

	local function compute_autocorrelation(buffer, lag)
		if buffer.count < lag + 4 then return 0 end

		local mean = buffer:average()
		local sum_product = 0
		local sum_sq = 0

		for i = 1, buffer.count - lag do
			local v1 = buffer:get(i) - mean
			local v2 = buffer:get(i + lag) - mean
			sum_product = sum_product + v1 * v2
			sum_sq = sum_sq + v1 * v1
		end

		if sum_sq < 0.001 then return 0 end
		return sum_product / sum_sq
	end

	local function detect_periodicity(buffer)
		if buffer.count < 8 then return 0, 0 end

		local best_period = 0
		local best_corr = 0

		for lag = 2, math.min(16, math.floor(buffer.count / 2)) do
			local corr = math.abs(compute_autocorrelation(buffer, lag))
			if corr > best_corr then
				best_corr = corr
				best_period = lag
			end
		end

		return best_period, best_corr
	end

	local function compute_symmetry(buffer)
		if buffer.count < 4 then return 0 end

		local positive = 0
		local negative = 0
		local mean = buffer:average()

		for i = 1, buffer.count do
			local v = buffer:get(i) - mean
			if v > 0 then positive = positive + 1
			elseif v < 0 then negative = negative + 1 end
		end

		local total = positive + negative
		if total == 0 then return 1 end

		local ratio = math.min(positive, negative) / math.max(positive, negative)
		return ratio
	end

	local function compute_coverage(buffer, expected_range)
		if buffer.count < 4 then return 0 end
		expected_range = expected_range or 120

		local min_val = buffer:min()
		local max_val = buffer:max()
		local actual_range = max_val - min_val

		return math.clamp(actual_range / expected_range, 0, 1)
	end

	aa_analytics.analyze = function ()
		local pd = analytics_data.pattern_detector
		local sa = analytics_data.self_analysis
		local now = globals.realtime()

		if now - pd.last_analysis < pd.analysis_interval then return end
		pd.last_analysis = now
		pd.analysis_count = pd.analysis_count + 1

		local start_time = globals.realtime()

		if pd.yaw_history.count < 8 then return end

		sa.yaw_variance = pd.yaw_history:variance()
		sa.body_variance = pd.body_history:variance()
		sa.yaw_stddev = pd.yaw_history:stddev()
		sa.body_stddev = pd.body_history:stddev()

		sa.effective_range = sa.yaw_stddev * 2

		sa.autocorrelation = math.abs(compute_autocorrelation(pd.yaw_history, 1))

		local period, periodicity = detect_periodicity(pd.yaw_history)
		sa.periodicity = periodicity

		sa.symmetry = compute_symmetry(pd.yaw_history)
		sa.coverage = compute_coverage(pd.yaw_history, 120)

		sa.predictability = sa.autocorrelation * 0.4
			+ sa.periodicity * 0.3
			+ (1 - math.clamp(sa.yaw_variance / 500, 0, 1)) * 0.2
			+ sa.symmetry * 0.1

		sa.predictability = math.clamp(sa.predictability, 0, 1)

		if pd.switch_history.count >= 6 then
			local transitions = 0
			for i = 1, pd.switch_history.count - 1 do
				if pd.switch_history:get(i) ~= pd.switch_history:get(i + 1) then
					transitions = transitions + 1
				end
			end
			local expected = (pd.switch_history.count - 1) * 0.5
			if expected > 0 then
				sa.switch_regularity = math.abs(transitions - expected) / expected
			end
		end

		local rec = analytics_data.recommendations
		local old_priority = rec.priority
		rec.priority = 0

		rec.increase_entropy = sa.predictability > 0.65
		rec.change_modifier = sa.yaw_variance < 30 and sa.coverage < 0.3
		rec.adjust_delay = sa.switch_regularity > 0.5
		rec.rotate_preset = confidence.get() < 0.30
		rec.widen_range = sa.coverage < 0.25 and sa.yaw_stddev < 10
		rec.break_symmetry = sa.symmetry > 0.85 and sa.periodicity > 0.5

		if rec.rotate_preset then
			rec.reason = "Critical confidence - preset rotation recommended"
			rec.priority = 5
		elseif rec.increase_entropy and rec.break_symmetry then
			rec.reason = "Highly predictable symmetric pattern"
			rec.priority = 4
		elseif rec.increase_entropy then
			rec.reason = "High autocorrelation detected"
			rec.priority = 3
		elseif rec.widen_range then
			rec.reason = "Yaw coverage too narrow"
			rec.priority = 2
		elseif rec.change_modifier then
			rec.reason = "Low yaw variance"
			rec.priority = 2
		elseif rec.adjust_delay then
			rec.reason = "Regular switch pattern detected"
			rec.priority = 1
		else
			rec.reason = ""
			rec.priority = 0
		end

		local elapsed = (globals.realtime() - start_time) * 1000
		analytics_data.performance.total_analyses = analytics_data.performance.total_analyses + 1
		analytics_data.performance.analysis_times:push(elapsed)
		analytics_data.performance.avg_analysis_time =
			analytics_data.performance.analysis_times:average()
	end

	aa_analytics.get_predictability = function ()
		return analytics_data.self_analysis.predictability
	end

	aa_analytics.get_periodicity = function ()
		return analytics_data.self_analysis.periodicity
	end

	aa_analytics.get_coverage = function ()
		return analytics_data.self_analysis.coverage
	end

	aa_analytics.get_recommendations = function ()
		return analytics_data.recommendations
	end

	aa_analytics.get_self_analysis = function ()
		return analytics_data.self_analysis
	end

	aa_analytics.get_entropy_bonus = function ()
		local sa = analytics_data.self_analysis
		local pred = sa.predictability

		if pred > 0.8 then
			return client.random_int(-18, 18)
		elseif pred > 0.65 then
			return client.random_int(-12, 12)
		elseif pred > 0.5 then
			return client.random_int(-6, 6)
		elseif pred > 0.35 then
			return client.random_int(-2, 2)
		end

		return 0
	end

	aa_analytics.get_symmetry_breaker = function ()
		local sa = analytics_data.self_analysis
		if sa.symmetry > 0.8 and sa.periodicity > 0.4 then
			local bias = (math.random() > 0.5) and 1 or -1
			return bias * client.random_int(3, 12)
		end
		return 0
	end

	aa_analytics.reset = function ()
		local pd = analytics_data.pattern_detector
		pd.yaw_history:clear()
		pd.body_history:clear()
		pd.switch_history:clear()
		pd.combined_history:clear()
		pd.analysis_count = 0

		local sa = analytics_data.self_analysis
		sa.predictability = 0
		sa.yaw_variance = 0
		sa.body_variance = 0
		sa.yaw_stddev = 0
		sa.body_stddev = 0
		sa.switch_regularity = 0
		sa.effective_range = 0
		sa.autocorrelation = 0
		sa.periodicity = 0
		sa.symmetry = 0
		sa.coverage = 0
	end

	timer_system.create(1.5, 0, function ()
		if my.valid and vars.antiaim.global.value then
			aa_analytics.analyze()
		end
	end)

	callbacks.round_start:set(function ()
		aa_analytics.reset()
	end)
end

