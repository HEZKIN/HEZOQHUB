-- #region - Performance Monitor

local perfmon = {} do
	local perf_data = {
		frametime = ring_buffer.new(128),
		ticktime = ring_buffer.new(64),

		fps = 0,
		avg_frametime = 0,
		worst_frametime = 0,
		best_frametime = math.huge,
		jitter = 0,
		percentile_99 = 0,
		percentile_1 = 0,

		auto_cheap = false,
		cheap_threshold_fps = 14,
		restore_threshold_fps = 22,
		cheap_hysteresis = 0,

		gc_pressure = 0,
		gc_total = 0,
		last_gc_count = 0,
		gc_history = ring_buffer.new(32),

		callback_times = {},
		slow_callbacks = {},

		memory = {
			current = 0,
			peak = 0,
			average = 0,
			samples = ring_buffer.new(32),
		},

		uptime = 0,
		start_time = globals.realtime(),
	}

	perfmon.update = function ()
		local ft = globals.absoluteframetime()
		local ft_ms = ft * 1000

		perf_data.frametime:push(ft_ms)

		perf_data.avg_frametime = perf_data.frametime:average()
		perf_data.worst_frametime = perf_data.frametime:max() or 0
		if ft_ms > 0 and ft_ms < perf_data.best_frametime then
			perf_data.best_frametime = ft_ms
		end
		perf_data.jitter = perf_data.frametime:stddev()

		if perf_data.avg_frametime > 0 then
			perf_data.fps = 1000 / perf_data.avg_frametime
		end

		local sorted = perf_data.frametime:to_array()
		table.sort(sorted)
		if #sorted > 0 then
			perf_data.percentile_99 = sorted[math.ceil(#sorted * 0.99)] or 0
			perf_data.percentile_1 = sorted[math.ceil(#sorted * 0.01)] or 0
		end

		local gc_count = collectgarbage("count")
		perf_data.gc_pressure = gc_count - perf_data.last_gc_count
		perf_data.gc_total = gc_count
		perf_data.last_gc_count = gc_count
		perf_data.gc_history:push(perf_data.gc_pressure)

		perf_data.memory.current = gc_count
		perf_data.memory.samples:push(gc_count)
		perf_data.memory.average = perf_data.memory.samples:average()
		if gc_count > perf_data.memory.peak then
			perf_data.memory.peak = gc_count
		end

		perf_data.uptime = globals.realtime() - perf_data.start_time

		if perf_data.fps < perf_data.cheap_threshold_fps then
			perf_data.cheap_hysteresis = perf_data.cheap_hysteresis + 1
		else
			perf_data.cheap_hysteresis = math.max(0, perf_data.cheap_hysteresis - 1)
		end

		if perf_data.cheap_hysteresis > 30 and not perf_data.auto_cheap then
			perf_data.auto_cheap = true
			render.cheap = true
			debug("Perfmon: auto-cheap ON (", math.round(perf_data.fps), " FPS)")
		elseif perf_data.fps > perf_data.restore_threshold_fps
		and perf_data.cheap_hysteresis == 0
		and perf_data.auto_cheap then
			perf_data.auto_cheap = false
			if not vars.visuals.cheap.value then
				render.cheap = false
			end
			debug("Perfmon: auto-cheap OFF (", math.round(perf_data.fps), " FPS)")
		end
	end

	perfmon.get_fps = function ()
		return perf_data.fps
	end

	perfmon.get_frametime = function ()
		return perf_data.avg_frametime
	end

	perfmon.get_worst_frametime = function ()
		return perf_data.worst_frametime
	end

	perfmon.get_jitter = function ()
		return perf_data.jitter
	end

	perfmon.get_gc_pressure = function ()
		return perf_data.gc_pressure
	end

	perfmon.get_memory = function ()
		return perf_data.memory
	end

	perfmon.get_uptime = function ()
		return perf_data.uptime
	end

	perfmon.is_auto_cheap = function ()
		return perf_data.auto_cheap
	end

	perfmon.benchmark = function (name, fn, ...)
		local start = globals.realtime()
		local results = {fn(...)}
		local elapsed = (globals.realtime() - start) * 1000

		if not perf_data.callback_times[name] then
			perf_data.callback_times[name] = ring_buffer.new(32)
		end
		perf_data.callback_times[name]:push(elapsed)

		if elapsed > 1.0 then
			perf_data.slow_callbacks[name] = elapsed
		end

		return unpack(results)
	end

	perfmon.get_callback_stats = function (name)
		local buf = perf_data.callback_times[name]
		if not buf then return nil end
		return {
			average = buf:average(),
			worst = buf:max(),
			best = buf:min(),
			stddev = buf:stddev(),
			samples = buf.count,
		}
	end

	perfmon.get_slow_callbacks = function ()
		return perf_data.slow_callbacks
	end

	perfmon.get_health_score = function ()
		local fps_score = math.clamp(perf_data.fps / 60, 0, 1)
		local jitter_score = math.clamp(1 - perf_data.jitter / 10, 0, 1)
		local gc_score = math.clamp(1 - math.abs(perf_data.gc_pressure) / 100, 0, 1)

		return fps_score * 0.5 + jitter_score * 0.3 + gc_score * 0.2
	end

	callbacks.paint_ui:set(perfmon.update)
end

