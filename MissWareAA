-- #region - Builder

antiaim.builder = {
	yaw = function (self, cmd, scene)
		local use = antiaim.data.useaa
		if use then return use[1], use[2], "Local view", {} end

		local stab = antiaim.features.stab:work()
		if stab then return stab[1], stab[2], nil, {} end

		local manual = antiaim.features.manual:work()
		if manual then return manual, nil, "Local view", {s = true} end

		return scene.yaw.offset, 89, nil, {}
	end,

	modifier = function (self, scene)
		if antiaim.data.static then return 0 end

		local side, value = 1, 0
		local modifier = scene.mod.type
		local degree = scene.mod.degree
		local range = scene.mod.range
		local eachway = scene.ways.manual
		local random = client.random_int(
			-scene.adv.irreg * 0.5,
			scene.adv.irreg * 0.5
		)

		local min = range and scene.mod.min or -degree
		local max = range and scene.mod.max or degree
		local addition = 0

		if scene.mod.add then
			if antiaim.my.side == 1 then
				addition = scene.mod.right
			elseif antiaim.my.side == -1 then
				addition = scene.mod.left
			end
		end

		if modifier == "Jitter" then
			value = (antiaim.my.switch and min or max) * side

		elseif modifier == "Random" then
			value = math.random(min, max)

		elseif modifier == "Rotate" then
			value = math.lerp(max, min, (globals.tickcount() * side) % 5 / 5)

		elseif modifier == "X-way" then
			antiaim.data.way = antiaim.data.way < (scene.ways.total - 1)
				and (antiaim.data.way + 1)
				or 0

			if eachway then
				value = scene.way[antiaim.data.way + 1]
			else
				local step = antiaim.data.way / (scene.ways.total - 1)
				value = math.lerp(min, max, step)
			end
		end

		return value + addition + random
	end,

	body = function (self, scene, modifier)
		if not scene.body.on then return end

		if vars.antiaim.general.warmup.value then
			if my.game_rules and entity.get_prop(my.game_rules, "m_bWarmupPeriod") == 1 then
				return
			end
		end

		local side, left, right = 0, 0, 0
		local should_relate = scene.mod.type == "X-way" and scene.body.relative

		if scene.body.mode == "Default" then
			left = scene.body.degree
			right = scene.body.degree

		elseif scene.body.mode == "Side-based" then
			left = scene.body.left
			right = scene.body.right

		elseif scene.body.mode == "Auto" then
			if should_relate then
				left, right = 0, 0
				goto processed
			end

			local overlap = adata.get_overlap(true)
			local cur, old = entity.get_simtime(my.entity)
			local fl = (cur and old) and toticks(cur - old) - 1 or 1
			local max_body = overlap * (fl < 2 and 30 or 60)

			left = modifier * math.gratio - max_body
			right = modifier * math.gratio + max_body
		end

		::processed::

		if should_relate then
			side = math.clamp(modifier, -1, 1)
		else
			side = ternary(
				scene.body.jitter,
				antiaim.my.switch,
				vars.antiaim.general.inverter:get()
			) and 1 or -1
		end

		if antiaim.data.static then side = 1 end

		local result
		if side == 0 then
			result = 0
		elseif side > 0 then
			result = left
		else
			result = right
		end

		antiaim.my.side = (result == 0 and (antiaim.my.switch and 1 or -1))
			or (result > 0 and 1)
			or (result < 0 and -1)

		return result
	end,

	work = function (self, cmd, scene, ctx)
		local yaw, pitch, base, flags = self:yaw(cmd, scene)

		antiaim.data.static = flags.s and vars.antiaim.general.manual.st.value
		local modifier = self:modifier(scene)
		local body = self:body(scene, modifier)

		ctx.pitch_mode = "Custom"
		ctx.pitch = pitch or 89
		ctx.base = base or ctx.base
		ctx.offset = math.normalize_yaw(yaw + modifier)
		ctx.body_yaw = body and "Static" or "Off"

		if body then
			ctx.body = math.clamp(body, -180, 180)
		end

		antiaim.my.last_yaw = ctx.offset
		antiaim.my.last_body = ctx.body or 0
	end
}

