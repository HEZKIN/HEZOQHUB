-- #region - String extensions

string.insert = function (a, b, pos)
	return string.sub(a, 1, pos) .. b .. string.sub(a, pos + 1)
end

string.limit = function (s, l, c)
	local r, i = {}, 1
	for w in string.gmatch(s, ".[\128-\191]*") do
		i, r[i] = i + 1, w
		if i > l then
			if c then r[i] = c == true and "..." or c end
			break
		end
	end
	return table.concat(r)
end

string.trim = function (s)
	return s:match("^%s*(.-)%s*$")
end

string.split = function (s, sep)
	local res = {}
	for part in s:gmatch("([^" .. (sep or ",") .. "]+)") do
		res[#res+1] = part
	end
	return res
end

string.starts_with = function (s, prefix)
	return s:sub(1, #prefix) == prefix
end

string.ends_with = function (s, suffix)
	return s:sub(-#suffix) == suffix
end

string.pad_left = function (s, len, char)
	char = char or " "
	return string.rep(char, math.max(0, len - #s)) .. s
end

string.pad_right = function (s, len, char)
	char = char or " "
	return s .. string.rep(char, math.max(0, len - #s))
end

string.contains = function (s, sub)
	return s:find(sub, 1, true) ~= nil
end

string.capitalize = function (s)
	return s:sub(1,1):upper() .. s:sub(2):lower()
end

string.count = function (s, sub)
	local n = 0
	local i = 1
	while true do
		local pos = s:find(sub, i, true)
		if not pos then break end
		n = n + 1
		i = pos + 1
	end
	return n
end

