-- #region : State machine

local state_machine = {} do
	state_machine.__index = state_machine

	function state_machine.new(initial_state)
		return setmetatable({
			current = initial_state,
			previous = nil,
			states = {},
			transitions = {},
			on_enter = {},
			on_exit = {},
			on_update = {},
			time_in_state = 0,
			transition_count = 0,
			history = ring_buffer.new(32),
		}, state_machine)
	end

	function state_machine:add_state(name, config)
		self.states[name] = config or {}
		if config then
			if config.on_enter then self.on_enter[name] = config.on_enter end
			if config.on_exit then self.on_exit[name] = config.on_exit end
			if config.on_update then self.on_update[name] = config.on_update end
		end
	end

	function state_machine:add_transition(from, to, condition)
		if not self.transitions[from] then self.transitions[from] = {} end
		self.transitions[from][#self.transitions[from]+1] = { to = to, condition = condition }
	end

	function state_machine:transition(new_state, force)
		if not force and self.current == new_state then return false end
		if not self.states[new_state] then return false end

		if self.on_exit[self.current] then
			self.on_exit[self.current](self, new_state)
		end

		self.previous = self.current
		self.current = new_state
		self.time_in_state = 0
		self.transition_count = self.transition_count + 1

		self.history:push({
			from = self.previous,
			to = new_state,
			time = globals.realtime(),
		})

		if self.on_enter[new_state] then
			self.on_enter[new_state](self, self.previous)
		end

		return true
	end

	function state_machine:update(dt)
		self.time_in_state = self.time_in_state + (dt or globals.absoluteframetime())

		local transitions = self.transitions[self.current]
		if transitions then
			for _, t in ipairs(transitions) do
				if t.condition(self) then
					self:transition(t.to)
					return
				end
			end
		end

		if self.on_update[self.current] then
			self.on_update[self.current](self, dt)
		end
	end

	function state_machine:is(state)
		return self.current == state
	end

	function state_machine:was(state)
		return self.previous == state
	end

	function state_machine:time()
		return self.time_in_state
	end
end

