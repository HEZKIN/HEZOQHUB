		"hud::logs.preview",
		pui.menu_open and vars.misc.logs.output:get("Screen") and #logger.list == 0
	)

	y = y + 4
	local ctx = self.preview > 0 and self.dummy or logger.list
	local to_remove = {}

	for i = 1, #ctx do
		local v = ctx[i]
		local ascend = (globals.realtime() - v.time) < 4 and i < 10
		local progress = anima.condition(
			v.progress,
			ternary(self.preview > 0, self.preview == 1, ascend)
		)

		if progress == 0 and not ascend then
			to_remove[#to_remove+1] = i
		end

		render.push_alpha(progress)
		self:part(v, y, progress, ascend, i)
		render.pop_alpha()

		y = y + 28 * (ascend and progress or 1)
	end

	for i = #to_remove, 1, -1 do
		table.remove(logger.list, to_remove[i])
	end
end

