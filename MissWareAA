-- #region - Drag system

local drag do
	local current

	local in_bounds = a(function (x, y, xa, ya, xb, yb)
		return (x >= xa and y >= ya) and (x <= xb and y <= yb)
	end)

	local progress = { menu = {0}, bg = {0} }

	callbacks.paint_ui:set(function ()
		local p1 = anima.condition(progress.bg, current ~= nil, 2)
		if p1 == 0 then return end
		render.push_alpha(p1)
		render.rectangle(0, 0, sw, sh, colors.panel.l1)
		render.pop_alpha()
	end)

	local process = a(function (self)
		local ctx = self.__drag
		if ctx.locked or not pui.menu_open then return end

		local held = mouse.pressed()
		local hovered = mouse.in_bounds(self.x, self.y, self.w, self.h)
			and not mouse.in_bounds(menu.x, menu.y, menu.w, menu.h)

		if held and ctx.ready == nil then
			ctx.ready = hovered
			ctx.ix, ctx.iy = self.x, self.y
			ctx.px, ctx.py = self.x - mouse.x, self.y - mouse.y
		end

		if held and ctx.ready then
			if current == nil and ctx.on_held then ctx.on_held(self, ctx) end
			current = (ctx.ready and current == nil) and self.id or current
			ctx.active = current == self.id
		elseif not held then
			if ctx.active and ctx.on_release then ctx.on_release(self, ctx) end
			ctx.active = false
			current = nil
			ctx.ready = nil
			ctx.aligning = nil
			ctx.px, ctx.py = nil, nil
			ctx.ix, ctx.iy = nil, nil
		end

		ctx.hovered = hovered or ctx.active

		local prefer = { nil, nil }
		local dx, dy, dw, dh = self.x * DPI, self.y * DPI, self.w * DPI, self.h * DPI
		local wx = ctx.px and (ctx.px + mouse.x) * DPI or dx
		local wy = ctx.py and (ctx.py + mouse.y) * DPI or dy
		local cx, cy = dx + dw * .5, dy + dh * .5

		local p1 = anima.condition(ctx.progress[1], ctx.hovered, 4)
		local p2 = anima.condition(ctx.progress[2], ctx.active, 4)

		render.rectangle(self.x - 3, self.y - 3, self.w + 6, self.h + 6, colors.white:alphen(12 + 24 * p1), 6)

		render.push_alpha(p2)

		if not client.key_state(0xA2) then
			local wcx = (wx + dw * .5) / DPI
			local wcy = (wy + dh * .5) / DPI

			for i, v in ipairs(ctx.rulers) do
				local spx, spy = v[2] / DPI, v[3] / DPI
				local dist = math.abs(v[1] and wcx - spx or wcy - spy)
				local allowed = dist < (10 * DPI)
				local pxy = v[1] and 1 or 2

				if not prefer[pxy] then
					prefer[pxy] = allowed
						and (v[1] and spx - self.w * .5 or spy - self.h * .5)
						or nil
				end

				v.p = v.p or {0}
				local adist = math.abs(v[1] and cx - spx or cy - spy)
				local pp = anima.condition(v.p, allowed or adist < (10 * DPI), -8) * .35 + 0.1
				render.rectangle(spx, spy, v[1] and 1 or v[4], v[1] and v[4] or 1, colors.white:alphen(pp, true))
			end

			if ctx.border[5] then
				local xa, ya = ctx.border[1], ctx.border[2]
				local xb, yb = ctx.border[3], ctx.border[4]
				local inside = in_bounds(self.x, self.y, xa, ya, xb - self.w * .5 - 1, yb - self.h * .5 - 1)
				local p3 = anima.condition(ctx.progress[3], not inside)
				render.rect_outline(xa, ya, xb - xa, yb - ya, colors.white:alphen(p3 * .75 + .25, true), 4)
			end
		end

		render.pop_alpha()

		if ctx.active then
			local fx = prefer[1] or wx / DPI
			local fy = prefer[2] or wy / DPI

			local min_x = (ctx.border[1] - dw * .5) / DPI
			local min_y = (ctx.border[2] - dh * .5) / DPI
			local max_x = (ctx.border[3] - dw * .5) / DPI
			local max_y = (ctx.border[4] - dh * .5) / DPI

			local x = math.clamp(fx, math.max(min_x, 0), math.min(max_x, sw - self.w))
			local y = math.clamp(fy, math.max(min_y, 0), math.min(max_y, sh - self.h))
			self:set_position(x, y)

			if ctx.on_active then ctx.on_active(self, ctx) end
		end
	end)

	drag = {
		new = a(function (widget_obj, props)
			vars.drag[widget_obj.id] = {
				x = pui.slider("MISC", "Settings", widget_obj.id .. ":x", 0, 10000,
					(widget_obj.x / sw) * 10000),
				y = pui.slider("MISC", "Settings", widget_obj.id .. ":y", 0, 10000,
					(widget_obj.y / sh) * 10000),
			}

			vars.drag[widget_obj.id].x:set_visible(false)
			vars.drag[widget_obj.id].y:set_visible(false)

			vars.drag[widget_obj.id].x:set_callback(function (this)
				widget_obj.x = math.round(this.value * .0001 * sw)
			end, true)
			vars.drag[widget_obj.id].y:set_callback(function (this)
				widget_obj.y = math.round(this.value * .0001 * sh)
			end, true)

			props = type(props) == "table" and props or {}

			widget_obj.__drag = {
				locked = false,
				active = false,
				hovered = nil,
				aligning = nil,
				progress = {{0}, {0}, {0}},
				ix = widget_obj.x,
				iy = widget_obj.y,
				px = nil,
				py = nil,
				border = props.border or {0, 0, asw, ash},
				rulers = props.rulers or {},
				on_release = props.on_release,
				on_held = props.on_held,
				on_active = props.on_active,
				config = vars.drag[widget_obj.id],
				work = process,
			}

			callbacks["missware::render_dpi"]:set(function (new)
				vars.drag[widget_obj.id].x:set(vars.drag[widget_obj.id].x.value)
				vars.drag[widget_obj.id].y:set(vars.drag[widget_obj.id].y.value)
			end)

			callbacks.setup_command:set(function (cmd)
				if pui.menu_open and (widget_obj.__drag.hovered or widget_obj.__drag.active) then
					cmd.in_attack = 0
				end
			end)
		end)
	}
end

