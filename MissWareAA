		if not self.data.scope.reserved and my.side ~= 0 then
			self.data.scope.target = -my.side
			self.data.scope.reserved = true
		end
	else
		self.data.scope.target = 0
		self.data.scope.reserved = false
	end

	self.data.scope.side = anima.lerp(
		crosshair.data.scope.side,
		crosshair.data.scope.target,
		12
	)

	return anima.condition(
		crosshair.progress,
		vars.visuals.crosshair.on.value and my.valid and not my.in_score
	)
