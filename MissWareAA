-- #region - Integration: Adaptive systems into AA manage

do
	local base_manage = antiaim.manage

	antiaim.manage = a(function (cmd)
		table.clear(antiaim.latest)
		local scene, ctx = antiaim.arrange()

		antiaim.builder:work(cmd, scene, ctx)

		local ab_adj = antibrute.get_adjustments()
		if ab_adj.yaw_offset ~= 0 or ab_adj.body_offset ~= 0 or ab_adj.jitter_override ~= 0 then
			ctx.offset = math.normalize_yaw(
				(ctx.offset or 0) + ab_adj.yaw_offset
			)
			if ctx.body then
				ctx.body = math.clamp(
					ctx.body + ab_adj.body_offset,
					-180, 180
				)
			end
			if ab_adj.pitch_adjust ~= 0 then
				ctx.pitch = math.normalize_pitch(
					(ctx.pitch or 89) + ab_adj.pitch_adjust
				)
			end
		end

		local entropy_bonus = aa_analytics.get_entropy_bonus()
		local symmetry_break = aa_analytics.get_symmetry_breaker()
		local total_bonus = entropy_bonus + symmetry_break

		if total_bonus ~= 0 then
			ctx.offset = math.normalize_yaw((ctx.offset or 0) + total_bonus)
		end

		antiaim.data.useaa = antiaim.features.on_use:work(cmd)
		antiaim.features.vulnlc:work(cmd)
		antiaim.features.fakelag:work(cmd)

		if not (antiaim.data.manual or antiaim.data.useaa) then
			antiaim.features.snap:work(cmd, ctx)
			antiaim.features.head:work(ctx)
		end

		if cmd.chokedcommands == 0 or antiaim.latest.force_send then
			antiaim.dispatch(ctx)
			if cmd.chokedcommands == 0 then
				antiaim.data.lifetime = antiaim.data.lifetime + 1
				antiaim.my.tick_counter = antiaim.my.tick_counter + 1

				if antiaim.features.restrict:work(cmd, scene) then
					antiaim.my.switch = not antiaim.my.switch
					antiaim.my.switch_count = antiaim.my.switch_count + 1
					antiaim.signals.on_switch:emit(antiaim.my.switch)
				end

				aa_analytics.record(ctx.offset, ctx.body, antiaim.my.switch)

				antiaim.history:push({
					tick = globals.tickcount(),
					time = globals.realtime(),
					state = antiaim.my.state,
					yaw = ctx.offset,
					body = ctx.body,
					pitch = ctx.pitch,
					switch = antiaim.my.switch,
					snapping = antiaim.latest.snapping,
					defensive = cmd.force_defensive,
					confidence = confidence.get(),
					confidence_level = select(2, confidence.get_level()),
					ab_phase = antibrute.get_phase(),
					ab_active = antibrute.is_active(),
					ab_state = antibrute.get_state(),
					entropy_bonus = entropy_bonus,
					symmetry_break = symmetry_break,
					predictability = aa_analytics.get_predictability(),
					threat_count = threat_intel.get_threat_count(1),
				})
			end
		end

		antiaim.data.defensive = cmd.force_defensive

		antiaim.my.entropy = (antiaim.my.entropy * 0.95)
			+ (math.abs((ctx.offset or 0) - antiaim.my.last_yaw) * 0.05)

		antiaim.my.last_yaw = ctx.offset or 0
		antiaim.my.last_body = ctx.body or 0
	end)
end

do
	callbacks["missware::enemy_shot"]:set(function (event)
		if event.damaged then
			antibrute.on_hit(event.attacker, nil, 0)
			confidence.record_preset_result(antiaim.my.state, true)
		else
			antibrute.on_miss(event.attacker)
			confidence.record_preset_result(antiaim.my.state, false)
		end
	end)

	callbacks.player_hurt:set(function (event)
		local target = client.userid_to_entindex(event.userid)
		local attacker = event.attacker ~= 0 and client.userid_to_entindex(event.attacker) or 0

		if target == my.entity and attacker ~= 0 then
			local is_enemy = pcall(entity.is_enemy, attacker) and entity.is_enemy(attacker)
			if is_enemy then
				antibrute.on_hit(attacker, event.hitgroup, event.dmg_health)
				confidence.record_preset_result(antiaim.my.state, true)
			end
		end
	end)
end

