-- #region : Render wrapper

local render do
	local alpha_value = 1
	local alpha_stack = {}
	local alpha_depth = 0

	local measurements = setmetatable({}, { __mode = "kv" })

	-- DPI handling
	local dpi_flag = ""
	local dpi_ref = ui.reference("MISC", "Settings", "DPI scale")

	_DPI.scalable = false
	_DPI.callback = function ()
		local old = DPI
		DPI = _DPI.scalable and tonumber(ui.get(dpi_ref):sub(1, -2)) * .01 or 1

		sw, sh = client.screen_size()
		sw, sh = sw / DPI, sh / DPI
		sc.x, sc.y = sw * .5, sh * .5
		dpi_flag = DPI ~= 1 and "d" or ""

		if old ~= DPI then
			callbacks["missware::render_dpi"]:fire(DPI)
			old = DPI
		end
	end

	_DPI.callback()
	ui.set_callback(dpi_ref, _DPI.callback)

	-- Blur system
	local blur_queue = {}

	do
		local function check_screen()
			if sw == 0 or sh == 0 then
				_DPI.callback()
				asw, ash = client.screen_size()
				sw, sh = render.screen_size()
			else
				callbacks.paint_ui:unset(check_screen)
			end
		end
		callbacks.paint_ui:set(check_screen)
	end

	callbacks.paint:set(function ()
		for i = 1, #blur_queue do
			local v = blur_queue[i]
			if v then renderer.blur(v[1], v[2], v[3], v[4]) end
		end
		table.clear(blur_queue)
	end)

	callbacks.paint_ui:set(function ()
		table.clear(blur_queue)
	end)

	local F, C, R = math.floor, math.ceil, math.round

	render = setmetatable({
		cheap = false,

		push_alpha = a(function (v)
			alpha_depth = alpha_depth + 1
			alpha_stack[alpha_depth] = alpha_value
			alpha_value = alpha_value * v
		end),

		pop_alpha = a(function ()
			if alpha_depth > 0 then
				alpha_value = alpha_stack[alpha_depth]
				alpha_stack[alpha_depth] = nil
				alpha_depth = alpha_depth - 1
			end
		end),

		get_alpha = a(function ()
			return alpha_value
		end),

		reset_alpha = a(function ()
			alpha_value = 1
			alpha_depth = 0
			table.clear(alpha_stack)
		end),

		blur = a(function (x, y, w, h, a_mul, s)
			if not render.cheap and my.valid and (a_mul or 1) * alpha_value > .25 then
				blur_queue[#blur_queue+1] = {F(x * DPI), F(y * DPI), F(w * DPI), F(h * DPI)}
			end
		end),

		gradient = a(function (x, y, w, h, c1, c2, dir)
			renderer.gradient(
				F(x * DPI), F(y * DPI), F(w * DPI), F(h * DPI),
				c1.r, c1.g, c1.b, c1.a * alpha_value,
				c2.r, c2.g, c2.b, c2.a * alpha_value,
				dir or false
			)
		end),

		line = a(function (xa, ya, xb, yb, c)
			renderer.line(
				F(xa * DPI), F(ya * DPI),
				F(xb * DPI), F(yb * DPI),
				c.r, c.g, c.b, c.a * alpha_value
			)
		end),

		rectangle = a(function (x, y, w, h, c, n)
			x, y, w, h, n = F(x * DPI), F(y * DPI), F(w * DPI), F(h * DPI), n and F(n * DPI) or 0
			local r, g, b, al = c.r, c.g, c.b, c.a * alpha_value

			if n == 0 then
				renderer.rectangle(x, y, w, h, r, g, b, al)
			else
				renderer.circle(x + n, y + n, r, g, b, al, n, 180, 0.25)
				renderer.rectangle(x + n, y, w - n - n, n, r, g, b, al)
				renderer.circle(x + w - n, y + n, r, g, b, al, n, 90, 0.25)
				renderer.rectangle(x, y + n, w, h - n - n, r, g, b, al)
				renderer.circle(x + n, y + h - n, r, g, b, al, n, 270, 0.25)
				renderer.rectangle(x + n, y + h - n, w - n - n, n, r, g, b, al)
				renderer.circle(x + w - n, y + h - n, r, g, b, al, n, 0, 0.25)
			end
		end),

		rect_outline = a(function (x, y, w, h, c, n, t)
			x, y, w, h = F(x * DPI), F(y * DPI), F(w * DPI), F(h * DPI)
			n, t = n and F(n * DPI) or 0, t and F(t * DPI) or 1
			local r, g, b, al = c.r, c.g, c.b, c.a * alpha_value

			if n == 0 then
				renderer.rectangle(x, y, w - t, t, r, g, b, al)
				renderer.rectangle(x, y + t, t, h - t, r, g, b, al)
				renderer.rectangle(x + w - t, y, t, h - t, r, g, b, al)
				renderer.rectangle(x + t, y + h - t, w - t, t, r, g, b, al)
			else
				renderer.circle_outline(x + n, y + n, r, g, b, al, n, 180, 0.25, t)
				renderer.rectangle(x + n, y, w - n - n, t, r, g, b, al)
				renderer.circle_outline(x + w - n, y + n, r, g, b, al, n, 270, 0.25, t)
				renderer.rectangle(x, y + n, t, h - n - n, r, g, b, al)
				renderer.circle_outline(x + n, y + h - n, r, g, b, al, n, 90, 0.25, t)
				renderer.rectangle(x + n, y + h - t, w - n - n, t, r, g, b, al)
				renderer.circle_outline(x + w - n, y + h - n, r, g, b, al, n, 0, 0.25, t)
				renderer.rectangle(x + w - t, y + n, t, h - n - n, r, g, b, al)
			end
		end),

		triangle = a(function (x1, y1, x2, y2, x3, y3, c)
			renderer.triangle(
				x1 * DPI, y1 * DPI,
				x2 * DPI, y2 * DPI,
				x3 * DPI, y3 * DPI,
				c.r, c.g, c.b, c.a * alpha_value
			)
		end),

		circle = a(function (x, y, c, radius, start, percentage)
			renderer.circle(
				x * DPI, y * DPI,
				c.r, c.g, c.b, c.a * alpha_value,
				radius * DPI, start or 0, percentage or 1
			)
		end),

		circle_outline = a(function (x, y, c, radius, start, percentage, thickness)
			renderer.circle_outline(
				x * DPI, y * DPI,
				c.r, c.g, c.b, c.a * alpha_value,
				radius * DPI, start or 0, percentage or 1,
				thickness * DPI
			)
		end),

		arc = a(function (x, y, c, radius, start, percentage, thickness, segments)
			local seg = segments or 32
			local step = (percentage or 1) / seg
			local angle = start or 0
			for i = 0, seg - 1 do
				local a1 = math.rad(angle + step * i * 360)
				local a2 = math.rad(angle + step * (i + 1) * 360)
				render.line(
					x + math.cos(a1) * radius, y + math.sin(a1) * radius,
					x + math.cos(a2) * radius, y + math.sin(a2) * radius,
					c
				)
			end
		end),

		screen_size = a(function (raw)
			local w, h = client.screen_size()
			if raw then return w, h else return w / DPI, h / DPI end
		end),

		load_rgba = a(function (c, w, h) return renderer.load_rgba(c, w, h) end),
		load_jpg = a(function (c, w, h) return renderer.load_jpg(c, w, h) end),
		load_png = a(function (c, w, h) return renderer.load_png(c, w, h) end),
		load_svg = a(function (c, w, h) return renderer.load_svg(c, w, h) end),

		texture = a(function (id, x, y, w, h, c, mode)
			if not id then return end
			renderer.texture(
				id,
				F(x * DPI), F(y * DPI), F(w * DPI), F(h * DPI),
				c.r, c.g, c.b, c.a * alpha_value,
				mode or "f"
			)
		end),

		text = a(function (x, y, c, flags, width, ...)
			renderer.text(
				x * DPI, y * DPI,
				c.r, c.g, c.b, c.a * alpha_value,
				(flags or "") .. dpi_flag,
				width or 0,
				...
			)
		end),

		measure_text = a(function (flags, text)
			if not text or text == "" then return 0, 0 end
			text = text:gsub("\a%x%x%x%x%x%x%x%x", "")
			flags = (flags or "")
			local key = string.format("<%s>%s", flags, text)
			if not measurements[key] or measurements[key][1] == 0 then
				measurements[key] = { renderer.measure_text(flags, text) }
			end
			return measurements[key][1], measurements[key][2]
		end),

		multiline_text = a(function (x, y, c, flags, spacing, ...)
			local lines = {...}
			local line_h = select(2, render.measure_text(flags, "A"))
			spacing = spacing or 2
			for i, line in ipairs(lines) do
				render.text(x, y + (i - 1) * (line_h + spacing), c, flags, nil, line)
			end
		end),
	}, {__index = renderer})
end

