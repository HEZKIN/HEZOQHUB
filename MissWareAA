antiaim.venture = {
	latest = 0,
	damaged = 0,
	shot_log = ring_buffer.new(64),
	attacker_data = {},

	trigger = function (event)
		if not my.valid then return end
		if antiaim.venture.latest == globals.tickcount() then return end

		local attacker = client.userid_to_entindex(event.userid)
		if not attacker then return end
		if not entity.is_enemy(attacker) then return end
		if entity.is_dormant(attacker) then return end

		local impact = vector(event.x, event.y, event.z)
		local enemy_view = vector(entity.get_origin(attacker))
		enemy_view.z = enemy_view.z + 64

		local dists = {}
		for i = 1, #players do
			local v = players[i]
			if not entity.is_enemy(v) then
				local head = vector(entity.hitbox_position(v, 0))
				if head then
					local point = math.closest_ray_point(head, enemy_view, impact)
					dists[#dists+1] = head:dist(point)
					if v == my.entity then dists.mine = dists[#dists] end
				end
			end
		end

		if #dists == 0 then return end
		local closest = math.min(unpack(dists))

		if (dists.mine and closest)
		and (dists.mine < 40 or (closest == dists.mine and dists.mine < 128))
		then
			antiaim.venture.shot_log:push({
				time = globals.realtime(),
				tick = globals.tickcount(),
				attacker = attacker,
				distance = dists.mine,
				closest = closest,
			})

			if not antiaim.venture.attacker_data[attacker] then
				antiaim.venture.attacker_data[attacker] = {
					shots = 0,
					hits = 0,
					misses = 0,
					last_shot = 0,
				}
			end
			antiaim.venture.attacker_data[attacker].shots =
				antiaim.venture.attacker_data[attacker].shots + 1
			antiaim.venture.attacker_data[attacker].last_shot = globals.realtime()

			client.delay_call(totime(1), function ()
				local was_damaged = antiaim.venture.latest == antiaim.venture.damaged

				if was_damaged then
					antiaim.venture.attacker_data[attacker].hits =
						(antiaim.venture.attacker_data[attacker].hits or 0) + 1
				else
					antiaim.venture.attacker_data[attacker].misses =
						(antiaim.venture.attacker_data[attacker].misses or 0) + 1
				end

				client.fire_event("missware::enemy_shot", {
					damaged = was_damaged,
					dist = dists.mine,
					attacker = attacker,
					userid = event.userid
				})
			end)

			antiaim.venture.latest = globals.tickcount()
			antiaim.features.restrict.ventured = math.random(1, 4)

			antiaim.signals.on_defensive:emit({
				attacker = attacker,
				distance = dists.mine,
			})
		end
	end,

	get_attacker_stats = function (self, ent)
		return self.attacker_data[ent]
	end,

	get_most_dangerous = function (self)
		local best_ent, best_shots = nil, 0
		for ent, data in pairs(self.attacker_data) do
			if data.shots > best_shots and entity.is_alive(ent) then
				best_ent = ent
				best_shots = data.shots
			end
		end
		return best_ent, best_shots
	end,

	reset = function (self)
		self.attacker_data = {}
		self.shot_log:clear()
	end,

	run = function (self)
		callbacks.bullet_impact:set(self.trigger)
		callbacks.player_hurt:set(function (event)
			if client.userid_to_entindex(event.userid) == my.entity then
				self.damaged = globals.tickcount()
			end
		end)
		callbacks.round_start:set(function ()
			self:reset()
		end)
	end
}

antiaim.venture:run()

