-- #region : Timer system

local timer_system = {} do
	local timers = {}
	local timer_id = 0

	timer_system.create = function (delay, repeats, callback)
		timer_id = timer_id + 1
		local id = timer_id
		timers[id] = {
			next_time = globals.realtime() + delay,
			delay = delay,
			repeats = repeats,
			callback = callback,
			paused = false,
			elapsed = 0,
		}
		return id
	end

	timer_system.remove = function (id)
		timers[id] = nil
	end

	timer_system.pause = function (id)
		if timers[id] then timers[id].paused = true end
	end

	timer_system.resume = function (id)
		if timers[id] then
			timers[id].paused = false
			timers[id].next_time = globals.realtime() + timers[id].delay
		end
	end

	timer_system.update = function ()
		local now = globals.realtime()
		local to_remove = {}

		for id, t in pairs(timers) do
			if not t.paused and now >= t.next_time then
				local ok, err = pcall(t.callback, id)
				if not ok then
					debug("Timer error: ", err)
					to_remove[#to_remove+1] = id
				else
					t.elapsed = t.elapsed + 1
					if t.repeats > 0 and t.elapsed >= t.repeats then
						to_remove[#to_remove+1] = id
					else
						t.next_time = now + t.delay
					end
				end
			end
		end

		for _, id in ipairs(to_remove) do
			timers[id] = nil
		end
	end

	callbacks.paint_ui:set(timer_system.update)
end

