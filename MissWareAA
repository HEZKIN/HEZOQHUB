-- #region : Color system

local color do
	local helpers = {
		RGBtoHEX = a(function (col, short)
			return string.format(
				short and "%02X%02X%02X" or "%02X%02X%02X%02X",
				col.r, col.g, col.b, col.a
			)
		end),
		HEXtoRGB = a(function (hex)
			hex = string.gsub(hex, "^#", "")
			return
				tonumber(string.sub(hex, 1, 2), 16),
				tonumber(string.sub(hex, 3, 4), 16),
				tonumber(string.sub(hex, 5, 6), 16),
				tonumber(string.sub(hex, 7, 8), 16) or 255
		end),
		HSVtoRGB = a(function (h, s, v)
			h = h % 360
			local c = v * s
			local x = c * (1 - math.abs((h / 60) % 2 - 1))
			local m = v - c
			local r, g, b
			if h < 60 then r, g, b = c, x, 0
			elseif h < 120 then r, g, b = x, c, 0
			elseif h < 180 then r, g, b = 0, c, x
			elseif h < 240 then r, g, b = 0, x, c
			elseif h < 300 then r, g, b = x, 0, c
			else r, g, b = c, 0, x end
			return math.floor((r + m) * 255), math.floor((g + m) * 255), math.floor((b + m) * 255)
		end),
		RGBtoHSV = a(function (r, g, b)
			r, g, b = r / 255, g / 255, b / 255
			local max = math.max(r, g, b)
			local min = math.min(r, g, b)
			local delta = max - min
			local h, s, v
			v = max
			if max == 0 then s = 0 else s = delta / max end
			if delta == 0 then
				h = 0
			elseif max == r then
				h = 60 * (((g - b) / delta) % 6)
			elseif max == g then
				h = 60 * ((b - r) / delta + 2)
			else
				h = 60 * ((r - g) / delta + 4)
			end
			return h, s, v
		end),
	}

	local create

	local mt = {
		__eq = a(function (a, b)
			return a.r == b.r and a.g == b.g and a.b == b.b and a.a == b.a
		end),
		__tostring = a(function (self)
			return string.format("rgba(%d, %d, %d, %d)", self.r, self.g, self.b, self.a)
		end),
		lerp = a(function (f, t, w)
			return create(
				f.r + (t.r - f.r) * w,
				f.g + (t.g - f.g) * w,
				f.b + (t.b - f.b) * w,
				f.a + (t.a - f.a) * w
			)
		end),
		to_hex = helpers.RGBtoHEX,
		to_hsv = a(function (self)
			return helpers.RGBtoHSV(self.r, self.g, self.b)
		end),
		alphen = a(function (self, a, r)
			return create(self.r, self.g, self.b, r and a * self.a or a)
		end),
		brighten = a(function (self, factor)
			return create(
				math.min(self.r * factor, 255),
				math.min(self.g * factor, 255),
				math.min(self.b * factor, 255),
				self.a
			)
		end),
		darken = a(function (self, factor)
			return create(
				self.r * (1 - factor),
				self.g * (1 - factor),
				self.b * (1 - factor),
				self.a
			)
		end),
		saturate = a(function (self, amount)
			local gray = 0.299 * self.r + 0.587 * self.g + 0.114 * self.b
			return create(
				math.clamp(gray + (self.r - gray) * (1 + amount), 0, 255),
				math.clamp(gray + (self.g - gray) * (1 + amount), 0, 255),
				math.clamp(gray + (self.b - gray) * (1 + amount), 0, 255),
				self.a
			)
		end),
		invert = a(function (self)
			return create(255 - self.r, 255 - self.g, 255 - self.b, self.a)
		end),
		grayscale = a(function (self)
			local g = math.floor(0.299 * self.r + 0.587 * self.g + 0.114 * self.b)
			return create(g, g, g, self.a)
		end),
		with_alpha = a(function (self, a)
			return create(self.r, self.g, self.b, a)
		end),
		mix = a(function (a, b, weight)
			weight = weight or 0.5
			return a:lerp(b, weight)
		end),
	}
	mt.__index = mt

	create = ffi.metatype(
		ffi.typeof("struct { uint8_t r; uint8_t g; uint8_t b; uint8_t a; }"),
		mt
	)

	color = setmetatable({
		rgb = a(function (r, g, b, a)
			r = math.min(r or 255, 255)
			return create(
				r,
				g and math.min(g, 255) or r,
				b and math.min(b, 255) or r,
				a and math.min(a, 255) or 255
			)
		end),
		hex = a(function (hex)
			local r, g, b, a = helpers.HEXtoRGB(hex)
			return create(r, g, b, a)
		end),
		hsv = a(function (h, s, v, a)
			local r, g, b = helpers.HSVtoRGB(h, s, v)
			return create(r, g, b, a or 255)
		end),
	}, {
		__call = a(function (self, r, g, b, a)
			return type(r) == "string" and self.hex(r) or self.rgb(r, g, b, a)
		end),
	})
end

