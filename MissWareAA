-- #region : Animation system

local anima do
	local mt = {}
	local animators = setmetatable({}, {__mode = "kv"})
	local frametime = globals.absoluteframetime()
	local g_speed = 1

	anima = {
		pulse = 0,

		easings = {
			pow = {
				function (x, p) return 1 - ((1 - x) ^ (p or 3)) end,
				function (x, p) return x ^ (p or 3) end,
				function (x, p)
					return x < 0.5
						and 4 * math.pow(x, p or 3)
						or 1 - math.pow(-2 * x + 2, p or 3) * 0.5
				end,
			},
			sine = {
				function (x) return 1 - math.cos(x * math.pi * 0.5) end,
				function (x) return math.sin(x * math.pi * 0.5) end,
				function (x) return -(math.cos(math.pi * x) - 1) * 0.5 end,
			},
			expo = {
				function (x) return x == 0 and 0 or 2 ^ (10 * x - 10) end,
				function (x) return x == 1 and 1 or 1 - 2 ^ (-10 * x) end,
				function (x)
					if x == 0 then return 0 end
					if x == 1 then return 1 end
					return x < 0.5
						and 2 ^ (20 * x - 10) * 0.5
						or (2 - 2 ^ (-20 * x + 10)) * 0.5
				end,
			},
			elastic = {
				function (x)
					if x == 0 then return 0 end
					if x == 1 then return 1 end
					return -2 ^ (10 * x - 10) * math.sin((x * 10 - 10.75) * (math.tau / 3))
				end,
				function (x)
					if x == 0 then return 0 end
					if x == 1 then return 1 end
					return 2 ^ (-10 * x) * math.sin((x * 10 - 0.75) * (math.tau / 3)) + 1
				end,
			},
			back = {
				function (x)
					local c1 = 1.70158
					local c3 = c1 + 1
					return c3 * x * x * x - c1 * x * x
				end,
				function (x)
					local c1 = 1.70158
					local c3 = c1 + 1
					return 1 + c3 * (x - 1) ^ 3 + c1 * (x - 1) ^ 2
				end,
			},
			bounce = {
				nil,
				function (x)
					local n1 = 7.5625
					local d1 = 2.75
					if x < 1 / d1 then
						return n1 * x * x
					elseif x < 2 / d1 then
						x = x - 1.5 / d1
						return n1 * x * x + 0.75
					elseif x < 2.5 / d1 then
						x = x - 2.25 / d1
						return n1 * x * x + 0.9375
					else
						x = x - 2.625 / d1
						return n1 * x * x + 0.984375
					end
				end,
			},
			circ = {
				function (x) return 1 - math.sqrt(1 - x * x) end,
				function (x) return math.sqrt(1 - (x - 1) ^ 2) end,
			},
		},

		lerp = a(function (a, b, s, t)
			local c = a + (b - a) * frametime * (s or 8) * g_speed
			return math.abs(b - c) < (t or .005) and b or c
		end),

		damp = a(function (a, b, smoothing, dt)
			return math.lerp(a, b, 1 - math.exp(-smoothing * (dt or frametime)))
		end),

		spring = a(function (current, target, velocity, config)
			config = config or {}
			local stiffness = config.stiffness or 100
			local damping = config.damping or 10
			local mass = config.mass or 1
			local dt = frametime

			local force = -stiffness * (current - target)
			local damping_force = -damping * velocity
			local acceleration = (force + damping_force) / mass
			velocity = velocity + acceleration * dt
			current = current + velocity * dt

			return current, velocity
		end),

		condition = a(function (id, c, s, e)
			local ctx = id[1] and id or animators[id]
			if not ctx then
				animators[id] = { c and 1 or 0, c }
				ctx = animators[id]
			end

			s = s or 4
			local cur_s = s
			if type(s) == "table" then
				cur_s = c and s[1] or s[2]
			end

			ctx[1] = math.clamp(
				ctx[1] + (frametime * math.abs(cur_s) * g_speed * (c and 1 or -1)),
				0, 1
			)

			return (ctx[1] % 1 == 0 or cur_s < 0) and ctx[1] or
				anima.easings.pow[e and (c and e[1][1] or e[2][1]) or (c and 1 or 3)](
					ctx[1],
					e and (c and e[1][2] or e[2][2]) or 3
				)
		end),

		sequence = a(function (id, steps, speed)
			local ctx = animators[id]
			if not ctx then
				animators[id] = { step = 1, t = 0 }
				ctx = animators[id]
			end

			ctx.t = ctx.t + frametime * (speed or 1)
			if ctx.t >= 1 then
				ctx.t = 0
				ctx.step = ctx.step % #steps + 1
			end

			return steps[ctx.step], ctx.t
		end),
	}

	mt = { __call = anima.condition }

	callbacks.paint_ui:set(function ()
		anima.pulse = math.abs(globals.realtime() * 1 % 2 - 1)
		frametime = globals.absoluteframetime()
	end)
end

