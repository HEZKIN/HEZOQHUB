-- #region : Spatial grid

local spatial_grid = {} do
	spatial_grid.__index = spatial_grid

	function spatial_grid.new(cell_size)
		return setmetatable({
			cell_size = cell_size or 256,
			cells = {},
		}, spatial_grid)
	end

	function spatial_grid:_key(x, y)
		local cx = math.floor(x / self.cell_size)
		local cy = math.floor(y / self.cell_size)
		return cx .. "," .. cy
	end

	function spatial_grid:insert(x, y, obj)
		local key = self:_key(x, y)
		if not self.cells[key] then self.cells[key] = {} end
		self.cells[key][obj] = true
	end

	function spatial_grid:remove(x, y, obj)
		local key = self:_key(x, y)
		if self.cells[key] then
			self.cells[key][obj] = nil
		end
	end

	function spatial_grid:query(x, y, radius)
		local results = {}
		local cells_needed = math.ceil(radius / self.cell_size) + 1
		local cx = math.floor(x / self.cell_size)
		local cy = math.floor(y / self.cell_size)

		for dx = -cells_needed, cells_needed do
			for dy = -cells_needed, cells_needed do
				local key = (cx + dx) .. "," .. (cy + dy)
				if self.cells[key] then
					for obj in pairs(self.cells[key]) do
						results[#results+1] = obj
					end
				end
			end
		end

		return results
	end

	function spatial_grid:clear()
		table.clear(self.cells)
	end
end

