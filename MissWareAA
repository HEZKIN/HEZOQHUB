-- #region - Math extensions

math.e = 2.71828182845905
math.gratio = 1.6180339887
math.tau = 6.28318530718
math.randomseed(client.timestamp() * 31337 + 7919)

math.round = function (v)
	return math.floor(v + 0.5)
end

math.roundb = function (v, d)
	local m = 10 ^ (d or 0)
	return math.floor(v * m + 0.5) / m
end

math.clamp = function (x, a, b)
	if a > x then return a
	elseif b < x then return b
	else return x end
end

math.lerp = function (a, b, w)
	return a + (b - a) * w
end

math.normalize_yaw = function (yaw)
	yaw = yaw % 360
	if yaw > 180 then yaw = yaw - 360 end
	if yaw < -180 then yaw = yaw + 360 end
	return yaw
end

math.normalize_pitch = function (pitch)
	return math.clamp(pitch, -89, 89)
end

math.closest_ray_point = function (p, s, e)
	local t, d = p - s, e - s
	local l = d:length()
	d = d / l
	local r = d:dot(t)
	if r < 0 then return s
	elseif r > l then return e end
	return s + d * r
end

math.remap = function (v, in_min, in_max, out_min, out_max)
	return out_min + (v - in_min) * (out_max - out_min) / (in_max - in_min)
end

math.smoothstep = function (edge0, edge1, x)
	local t = math.clamp((x - edge0) / (edge1 - edge0), 0, 1)
	return t * t * (3 - 2 * t)
end

math.smootherstep = function (edge0, edge1, x)
	local t = math.clamp((x - edge0) / (edge1 - edge0), 0, 1)
	return t * t * t * (t * (t * 6 - 15) + 10)
end

math.angle_diff = function (a, b)
	local diff = math.normalize_yaw(a - b)
	return diff
end

math.approach = function (cur, target, speed)
	local diff = target - cur
	if diff > speed then return cur + speed
	elseif diff < -speed then return cur - speed end
	return target
end

math.bias = function (x, b)
	return x / ((1 / b - 2) * (1 - x) + 1)
end

math.gain = function (x, g)
	if x < 0.5 then
		return math.bias(x * 2, g) * 0.5
	end
	return math.bias(x * 2 - 1, 1 - g) * 0.5 + 0.5
end

math.damped_spring = function (current, target, velocity, damping, stiffness, dt)
	local displacement = current - target
	local spring_force = -stiffness * displacement
	local damping_force = -damping * velocity
	local acceleration = spring_force + damping_force
	velocity = velocity + acceleration * dt
	current = current + velocity * dt
	return current, velocity
end

math.bezier_quadratic = function (t, p0, p1, p2)
	local u = 1 - t
	return u * u * p0 + 2 * u * t * p1 + t * t * p2
end

math.bezier_cubic = function (t, p0, p1, p2, p3)
	local u = 1 - t
	return u*u*u*p0 + 3*u*u*t*p1 + 3*u*t*t*p2 + t*t*t*p3
end

math.wrap = function (v, min, max)
	local range = max - min
	return min + (v - min) % range
end

math.snap = function (v, grid)
	return math.floor(v / grid + 0.5) * grid
end

math.is_finite = function (v)
	return v == v and v ~= math.huge and v ~= -math.huge
end

math.sign = function (v)
	if v > 0 then return 1
	elseif v < 0 then return -1
	else return 0 end
end

math.inverse_lerp = function (a, b, v)
	if a == b then return 0 end
	return (v - a) / (b - a)
end

math.move_towards = function (current, target, max_delta)
	if math.abs(target - current) <= max_delta then return target end
	return current + math.sign(target - current) * max_delta
end

math.ping_pong = function (t, length)
	t = t % (length * 2)
	return length - math.abs(t - length)
end

math.decay = function (a, b, decay, dt)
	return b + (a - b) * math.exp(-decay * dt)
end

