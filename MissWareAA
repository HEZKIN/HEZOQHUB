-- #region : Ring buffer

local ring_buffer = {} do
	ring_buffer.__index = ring_buffer

	function ring_buffer.new(capacity)
		return setmetatable({
			capacity = capacity,
			data = {},
			head = 0,
			count = 0,
		}, ring_buffer)
	end

	function ring_buffer:push(value)
		self.head = (self.head % self.capacity) + 1
		self.data[self.head] = value
		if self.count < self.capacity then
			self.count = self.count + 1
		end
	end

	function ring_buffer:get(index)
		if index < 1 or index > self.count then return nil end
		local actual = ((self.head - index) % self.capacity) + 1
		return self.data[actual]
	end

	function ring_buffer:latest()
		if self.count == 0 then return nil end
		return self.data[self.head]
	end

	function ring_buffer:oldest()
		if self.count == 0 then return nil end
		local idx = ((self.head - self.count) % self.capacity) + 1
		return self.data[idx]
	end

	function ring_buffer:clear()
		table.clear(self.data)
		self.head = 0
		self.count = 0
	end

	function ring_buffer:size()
		return self.count
	end

	function ring_buffer:full()
		return self.count >= self.capacity
	end

	function ring_buffer:iterate()
		local i = 0
		return function ()
			i = i + 1
			if i > self.count then return nil end
			return i, self:get(i)
		end
	end

	function ring_buffer:to_array()
		local arr = {}
		for i = 1, self.count do
			arr[i] = self:get(i)
		end
		return arr
	end

	function ring_buffer:average(field)
		if self.count == 0 then return 0 end
		local sum = 0
		for i = 1, self.count do
			local v = self:get(i)
			sum = sum + (field and v[field] or v)
		end
		return sum / self.count
	end

	function ring_buffer:max(field)
		if self.count == 0 then return nil end
		local best = nil
		for i = 1, self.count do
			local v = self:get(i)
			local val = field and v[field] or v
			if best == nil or val > best then best = val end
		end
		return best
	end

	function ring_buffer:min(field)
		if self.count == 0 then return nil end
		local best = nil
		for i = 1, self.count do
			local v = self:get(i)
			local val = field and v[field] or v
			if best == nil or val < best then best = val end
		end
		return best
	end

	function ring_buffer:variance(field)
		if self.count < 2 then return 0 end
		local avg = self:average(field)
		local sum = 0
		for i = 1, self.count do
			local v = self:get(i)
			local val = field and v[field] or v
			sum = sum + (val - avg) ^ 2
		end
		return sum / (self.count - 1)
	end

	function ring_buffer:stddev(field)
		return math.sqrt(self:variance(field))
	end

	function ring_buffer:median(field)
		if self.count == 0 then return 0 end
		local arr = {}
		for i = 1, self.count do
			local v = self:get(i)
			arr[i] = field and v[field] or v
		end
		table.sort(arr)
		local mid = math.floor(self.count / 2)
		if self.count % 2 == 0 then
			return (arr[mid] + arr[mid + 1]) * 0.5
		end
		return arr[mid + 1]
	end

	function ring_buffer:weighted_average(field, decay)
		if self.count == 0 then return 0 end
		decay = decay or 0.9
		local sum, weight_sum = 0, 0
		for i = 1, self.count do
			local v = self:get(i)
			local val = field and v[field] or v
			local w = decay ^ (i - 1)
			sum = sum + val * w
			weight_sum = weight_sum + w
		end
		return sum / weight_sum
	end

	function ring_buffer:count_where(fn)
		local n = 0
		for i = 1, self.count do
			if fn(self:get(i)) then n = n + 1 end
		end
		return n
	end

	function ring_buffer:find_where(fn)
		for i = 1, self.count do
			local v = self:get(i)
			if fn(v) then return v, i end
		end
		return nil
	end

	function ring_buffer:filter(fn)
		local res = {}
		for i = 1, self.count do
			local v = self:get(i)
			if fn(v) then res[#res+1] = v end
		end
		return res
	end
end

