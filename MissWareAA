-- #region - Performance stats widget (debug only)

hud.perf_stats = widget.new("perf_stats", 24, 24, 180, 110)

hud.perf_stats.update = function (self)
	return anima.condition(
		self.progress,
		_DEBUG and my.in_game,
		-4
	)
end

hud.perf_stats.paint = function (self, x, y, w, h)
	local white = color.rgb(255, 255, 255)
	local text = colors.text or white
	local red = colors.red or text
	local yellow = colors.yellow or text
	local green = colors.green or text
	local accent = colors.accent or text

	render.blur(x, y, w, h)
	render.rectangle(x, y, w, h, colors.panel.l1, 4)
	render.rect_outline(x, y, w, h, accent:alphen(24), 4)

	local fps = perfmon.get_fps()
	local ft = perfmon.get_frametime()
	local jitter = perfmon.get_jitter()
	local gc = perfmon.get_gc_pressure()
	local mem = perfmon.get_memory()
	local health = perfmon.get_health_score()

	local fps_col
	if fps > 120 then fps_col = accent
	elseif fps > 60 then fps_col = green
	elseif fps > 30 then fps_col = yellow
	else fps_col = red end

	local line_h = 13
	local cy = y + 4

	render.text(x + 6, cy, text:alphen(128), nil, nil, "PERFORMANCE")
	cy = cy + line_h + 2

	render.text(x + 6, cy, fps_col, nil, nil,
		string.format("FPS: %d (%.1fms)", math.round(fps), ft))
	cy = cy + line_h

	render.text(x + 6, cy, text:alphen(160), nil, nil,
		string.format("Jitter: %.2fms | P99: %.1fms", jitter, perfmon.get_worst_frametime()))
	cy = cy + line_h

	render.text(x + 6, cy, text:alphen(160), nil, nil,
		string.format("Mem: %.0fkb (peak: %.0fkb)", mem.current, mem.peak))
	cy = cy + line_h

	render.text(x + 6, cy, text:alphen(160), nil, nil,
		string.format("GC: %+.1fkb/f", gc))
	cy = cy + line_h

	local conf = confidence.get()
	local level_name = confidence.get_level()
	local pred = aa_analytics.get_predictability()

	render.text(x + 6, cy, accent:alphen(160), nil, nil,
		string.format("Conf: %s %d%% | Pred: %d%%",
			level_name, math.round(conf * 100), math.round(pred * 100)))
	cy = cy + line_h

	local ab_state_name = antibrute.get_state()
	local ab_phase = antibrute.get_phase()
	local ab_eff = antibrute.get_effectiveness()
	render.text(x + 6, cy, text:alphen(120), nil, nil,
		string.format("AB: %s p%d eff:%d%%", ab_state_name, ab_phase, math.round(ab_eff * 100)))

	if perfmon.is_auto_cheap() then
		render.text(x + w - 6, y + 4, yellow, "r", nil, "AUTO-CHEAP")
	end

	local health_col = health > 0.7 and green or (health > 0.4 and yellow or red)
	render.rectangle(x + 6, y + h - 6, w - 12, 3, colors.black:alphen(64), 1)
	render.rectangle(x + 6, y + h - 6, (w - 12) * health, 3, health_col, 1)
end

