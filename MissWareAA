client.extrapolate = function (x, y, z, velocity, ticks)
	local time = globals.tickinterval() * ticks
	return x + (velocity.x * time), y + (velocity.y * time), z + (velocity.z * time)
end

client.extrapolate_gravity = function (x, y, z, velocity, ticks, gravity)
	gravity = gravity or 800
	local time = globals.tickinterval() * ticks
	local half_g = 0.5 * gravity * time * time
	return x + (velocity.x * time), y + (velocity.y * time), z + (velocity.z * time) - half_g
end

