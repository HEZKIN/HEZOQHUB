		if not player_profiles[entindex] then
			local profile = profile_pool:acquire()
			profile.entindex = entindex
			profile.first_seen = globals.realtime()
			profile.last_seen = globals.realtime()

			local ok, name = pcall(entity.get_player_name, entindex)
			if ok and name then profile.name = name end

			player_profiles[entindex] = profile
		end

		player_profiles[entindex].last_seen = globals.realtime()
		return player_profiles[entindex]
	end

	threat_intel.remove_profile = function (entindex)
		if player_profiles[entindex] then
			profile_pool:release(player_profiles[entindex])
			player_profiles[entindex] = nil
		end
	end

	threat_intel.has_profile = function (entindex)
		return player_profiles[entindex] ~= nil
	end

