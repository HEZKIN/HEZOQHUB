misc.aspect = {
	active = false,
	value = sw / sh,
	init = sw / sh,
	activate = function ()
		misc.aspect.active = true
	end,
	work = function ()
		local self, ctx = misc.aspect, vars.misc.aspect
		if not self.active then return end

		if ctx.on.value then
			local target = ctx.ratio.value * .01
			self.value = anima.lerp(self.value, target, 8, .001)
