	local x, y = sc.x, self.y
	local m = anima.condition("crosshair::yposition", self.y > sc.y, 3) * 2 - 1
	local side = crosshair.data.scope.side
	local offset = side * 0.5 + 0.5

	for i, v in ipairs(self.items) do
