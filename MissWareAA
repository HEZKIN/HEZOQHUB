-- #region : Signal / event system

local signal = {} do
	signal.__index = signal

	function signal.new()
		return setmetatable({
			listeners = {},
			once_listeners = {},
		}, signal)
	end

	function signal:connect(fn, priority)
		self.listeners[#self.listeners+1] = { fn = fn, priority = priority or 0 }
		table.sort(self.listeners, function (a, b) return a.priority > b.priority end)
		return fn
	end

	function signal:once(fn, priority)
		self.once_listeners[#self.once_listeners+1] = { fn = fn, priority = priority or 0 }
	end

	function signal:disconnect(fn)
		for i = #self.listeners, 1, -1 do
			if self.listeners[i].fn == fn then
				table.remove(self.listeners, i)
				return true
			end
		end
		return false
	end

	function signal:emit(...)
		for _, listener in ipairs(self.listeners) do
			listener.fn(...)
		end

		for _, listener in ipairs(self.once_listeners) do
			listener.fn(...)
		end
		table.clear(self.once_listeners)
	end

	function signal:clear()
		table.clear(self.listeners)
		table.clear(self.once_listeners)
	end

	function signal:count()
		return #self.listeners
	end
end

