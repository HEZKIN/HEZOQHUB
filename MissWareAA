hud.threat_radar.paint = function (self, x, y, w, h)
	local white = color.rgb(255, 255, 255)
	local text = (colors and colors.text) or white

	local function get_safe_color(c)
		if c and type(c) == "cdata" then return c end
		return text
	end

	local red = get_safe_color(colors and colors.red)
	local yellow = get_safe_color(colors and colors.yellow)
	local green = get_safe_color(colors and colors.green)
	local accent = get_safe_color(colors and colors.accent)
	local panel_l1 = get_safe_color(colors and colors.panel and colors.panel.l1)

	local cx, cy = x + w * 0.5, y + h * 0.5
	local radius = w * 0.4

	render.blur(x, y, w, h)
	render.rectangle(x, y, w, h, panel_l1, 8)
	render.rect_outline(x, y, w, h, accent.alphen and accent:alphen(24) or accent, 8)

	render.circle_outline(cx, cy, accent.alphen and accent:alphen(20) or accent, radius, 0, 1, 1)
	render.circle_outline(cx, cy, accent.alphen and accent:alphen(12) or accent, radius * 0.66, 0, 1, 1)
	render.circle_outline(cx, cy, accent.alphen and accent:alphen(8) or accent, radius * 0.33, 0, 1, 1)

	render.line(cx - radius, cy, cx + radius, cy, accent.alphen and accent:alphen(12) or accent)
	render.line(cx, cy - radius, cx, cy + radius, accent.alphen and accent:alphen(12) or accent)

	self.data.sweep_angle = (self.data.sweep_angle + globals.absoluteframetime() * 60) % 360
	local sweep_rad = math.rad(self.data.sweep_angle)
	render.line(
		cx, cy,
		cx + math.cos(sweep_rad) * radius,
		cy + math.sin(sweep_rad) * radius,
		accent.alphen and accent:alphen(40) or accent
	)

	local trail_count = 8
	for t = 1, trail_count do
		local trail_angle = math.rad(self.data.sweep_angle - t * 4)
		local trail_alpha = (1 - t / trail_count) * 20
		render.line(
			cx, cy,
			cx + math.cos(trail_angle) * radius,
			cy + math.sin(trail_angle) * radius,
			accent.alphen and accent:alphen(trail_alpha) or accent
		)
	end

	render.circle(cx, cy, accent.alphen and accent:alphen(100) or accent, 2)

	if not my.valid then return end

	local cam_pitch, cam_yaw = client.camera_angles()
	local threats = threat_intel.get_active_threats(0.05)

	for _, threat_data in ipairs(threats) do
		local ent = threat_data.entindex
		local profile = threat_data.profile
		local score = threat_data.score

		if entity.is_dormant(ent) then goto skip_blip end

		local origin = profile.position.current
		if not origin or origin:length() == 0 then goto skip_blip end

		local diff = origin - my.origin
		local dist = diff:length2d()
		local angle = math.deg(math.atan2(diff.y, diff.x)) - cam_yaw - 90

		local norm_dist = math.clamp(dist / 2000, 0, 0.92)
		local bx = cx + math.cos(math.rad(angle)) * radius * norm_dist
		local by = cy - math.sin(math.rad(angle)) * radius * norm_dist

		local dot_size = math.lerp(2, 5, score)

		local threat_col
		if profile.danger_level >= 4 then
			threat_col = red
		elseif profile.danger_level >= 3 then
			threat_col = red:lerp(yellow, 0.4)
		elseif profile.danger_level >= 2 then
			threat_col = yellow
		elseif profile.danger_level >= 1 then
			threat_col = green
		else
			threat_col = text:alphen(64)
		end

		render.circle(bx, by, threat_col:alphen(200), dot_size)

		if profile.danger_level >= 3 then
			local pulse = math.abs(math.sin(globals.realtime() * 4 + ent * 0.7))
			render.circle_outline(bx, by, threat_col:alphen(pulse * 100), dot_size + 4, 0, 1, 1)
		end

		if profile.angles.looking_at_me then
			render.circle_outline(bx, by, red:alphen(80), dot_size + 2, 0, 1, 1)
		end

		::skip_blip::
	end

	render.text(x + 4, y + 4, text:alphen(96), nil, nil, "THREAT RADAR")

	local evasion = threat_intel.get_evasion_rate()
	local evasion_col = evasion > 0.8 and green
		or (evasion > 0.5 and yellow or red)
	render.text(
		x + w - 4, y + h - 14,
		evasion_col:alphen(180), "r", nil,
		string.format("EVD %d%%", math.round(evasion * 100))
	)

	local streak = threat_intel.get_global_stats().current_evasion_streak
	if streak >= 3 then
		render.text(
			x + 4, y + h - 14,
			accent:alphen(160), nil, nil,
			string.format("×%d", streak)
		)
	end
end

