-- #region - Anti-brute phase indicator

hud.ab_indicator = widget.new("ab_indicator", sc.x + 80, sc.y - 20, 48, 48, {
	border = { asc.x, asc.y - 60, asc.x + 200, asc.y + 60 },
})

hud.ab_indicator.ring_progress = 0
hud.ab_indicator.pulse = 0
hud.ab_indicator.phase_anim = 0

hud.ab_indicator.update = function (self)
	return anima.condition(
		self.progress,
		antibrute.is_active() and vars.antiaim.global.value and my.valid,
		-6
	)
end

hud.ab_indicator.paint = function (self, x, y, w, h)
	local white = color.rgb(255, 255, 255)
	local text = (colors and colors.text) or white

	local function get_safe_color(c)
		if c and type(c) == "cdata" then return c end
		return text
	end

	local red = get_safe_color(colors and colors.red)
	local yellow = get_safe_color(colors and colors.yellow)
	local accent = get_safe_color(colors and colors.accent)

	local cx, cy = x + w * 0.5, y + h * 0.5
	local radius = w * 0.4

	local phase = antibrute.get_phase()
	local state = antibrute.get_state()
	local eff = antibrute.get_effectiveness()
	local rotations = antibrute.get_round_rotations()

	self.ring_progress = anima.lerp(self.ring_progress, eff, 8)
	self.phase_anim = anima.lerp(self.phase_anim, phase, 12)

	local state_colors = {
		idle = (text.alphen and text:alphen(64)) or text,
		alert = (yellow.alphen and yellow:alphen(128)) or yellow,
		monitoring = yellow,
		rotating = accent,
		emergency = red,
		lockdown = (red.darken and red:darken(0.3)) or red,
	}

	local col = state_colors[state] or text

	render.blur(x, y, w, h)
	render.rectangle(x, y, w, h, colors.panel.l1, 8)

	render.circle_outline(cx, cy, colors.white:alphen(12), radius, 0, 1, 1)

	local seg_count = 8
	for s = 0, seg_count - 1 do
		local seg_start = (s / seg_count) * 360 - 90
		local seg_size = 1 / seg_count - 0.01
		local seg_col = s == phase and col or colors.white:alphen(16)

		render.circle_outline(cx, cy, seg_col, radius, seg_start, seg_size, 2)
	end

	render.circle_outline(cx, cy, col:alphen(180), radius - 4, -90, self.ring_progress, 1)

	render.text(cx, cy - 5, col, "c-b", nil, tostring(phase))
	render.text(cx, cy + 8, text:alphen(48), "c-", nil, "AB")

	if state == "rotating" or state == "emergency" then
		self.pulse = self.pulse + globals.absoluteframetime() * 6
		local p = math.abs(math.sin(self.pulse))
		render.circle_outline(cx, cy, col:alphen(p * 60), radius + 4, 0, 1, 1)
	elseif state == "lockdown" then
		self.pulse = self.pulse + globals.absoluteframetime() * 2
		local p = math.abs(math.sin(self.pulse))
		render.rect_outline(x - 2, y - 2, w + 4, h + 4, red:alphen(p * 40), 10)
	else
		self.pulse = 0
	end

	if rotations > 0 then
		render.text(
			x + w - 2, y + 2,
			text:alphen(64), "r-", nil,
			string.format("x%d", rotations)
		)
	end
end

